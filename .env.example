# ─────────────────────────────────────────────────────────────────
# Varuna Case Management — environment değişkenleri (on-prem)
# .env'e kopyalayıp gerçek değerleri yaz. Kurulum: docs/ONPREM_INSTALL.md
# ─────────────────────────────────────────────────────────────────

# Sunucu portu (UI + API aynı süreçte servis edilir)
PORT=3101
# Dinlenecek arayüz. Reverse proxy (IIS/nginx) arkasında 127.0.0.1 yap ki
# port dışarıya kapansın (bkz. docs/IIS_DEPLOY.md). Boş = tüm arayüzler.
HOST=
# Frontend FARKLI bir origin'den sunulacaksa doldur; aynı süreçten servis
# ediliyorsa (varsayılan) boş bırak.
CORS_ORIGIN=
# Zamanlanmış job'ları (snooze/pattern/qa/cleanup/archive) kapatmak için false
CRON_SCHEDULER_ENABLED=true

# OpenAI API key — RUNA AI özellikleri için
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_key_here

# ─────────────────────────────────────────────────────────────────
# MSSQL bağlantısı (on-prem)
# Named instance kullanılıyorsa instance'ın GERÇEK TCP portunu yaz
# (Prisma SQL Browser çözümlemesi yapmaz). Portu öğrenmek için:
#   SELECT local_tcp_port FROM sys.dm_exec_connections WHERE session_id=@@SPID
# Not: dinamik port sunucu restart'ında değişebilir — SQL Server
# Configuration Manager'dan statik port sabitlenmesi önerilir.
# ─────────────────────────────────────────────────────────────────
DATABASE_URL="sqlserver://<host>:<port>;database=VarunaCaseManagement;user=<user>;password=<password>;encrypt=false;trustServerCertificate=true"

# ─────────────────────────────────────────────────────────────────
# Local auth (Faz 3) — JWT imza secret'ları
# JWT_SECRET / JWT_REFRESH_SECRET: en az 16 (önerilen 32+) karakter,
# birbirinden FARKLI rastgele string'ler. Production'da mutlaka değiştir.
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=<rastgele-32+karakter>
JWT_REFRESH_SECRET=<farkli-rastgele-32+karakter>
JWT_ACCESS_EXPIRY=30m
JWT_REFRESH_EXPIRY=7d

# ─────────────────────────────────────────────────────────────────
# Local disk storage (Faz 4) — vaka ekleri bu dizinde saklanır.
# Mutlak path önerilir (örn. D:\varuna-data\attachments); boşsa
# ./data/attachments kullanılır. Yedeklemeye dahil edilmeli.
# ─────────────────────────────────────────────────────────────────
STORAGE_ROOT=D:\varuna-data\attachments

# ─────────────────────────────────────────────────────────────────
# Eylem Merkezi (WR-ACTION-CENTER Phase 1) — Approval Visibility MVP.
# Browser'a expose edilen Vite build-time flag (VITE_ prefix).
# true → üst menüdeki Eylem Merkezi zili + Benim Sayfam "Bekleyen
# Onaylarım" paneli + drawer render edilir. Backend her durumda
# ActionItem yazar; flag yalnız UI görünürlüğünü kontrol eder.
# Vercel'de değiştirdikten sonra production redeploy yapılmalı —
# VITE_* değerleri build sırasında bundle'a inline edilir.
# ─────────────────────────────────────────────────────────────────
VITE_ACTION_CENTER_ENABLED=true

# ─────────────────────────────────────────────────────────────────
# Eski bahsetme zili (WR-NOTIFICATION-CENTER Phase 2A geçişi).
# Default false → yalnız tek "Aksiyonlarım" zili render edilir.
# true yapılırsa sağdaki eski MentionBellBadge geri gelir
# (Phase 2A boyunca acil rollback yolu; Phase 3'te component
# tamamen silinecek). Vercel'de değiştirdikten sonra production
# redeploy gerekir.
# ─────────────────────────────────────────────────────────────────
VITE_LEGACY_MENTION_BELL_ENABLED=false

# ─────────────────────────────────────────────────────────────────
# L1 Case Resolution Console (Phase 1 — layout shell).
# true → klasik CaseDetailPage yerine L1CaseResolutionConsole render
# edilir. Default false (dev + prod). Phase 1 PR'ında yalnız 3-zone
# shell + stub component'ler var; gerçek davranış sonraki fazlarda
# gelir. Flag false iken zero runtime impact.
# ─────────────────────────────────────────────────────────────────
VITE_L1_CASE_CONSOLE_ENABLED=false

# ─────────────────────────────────────────────────────────────────
# Smart Ticket Intake (WR-Smart-Ticket Phase 1c+).
# true → Vakalar listesi üst aksiyonlarında "Akıllı Ticket" butonu
# görünür ve `smart-ticket-new` route render edilir. Buton/route
# tek kapısı bu flag'dir — ek rol gating yok (Cases sayfasına
# erişebilen herkes butonu görür). Default IS_DEV: dev ortamında
# açık, production'da kapalı.
# Backend ve API sözleşmeleri flag durumundan bağımsız çalışır:
# POST /api/cases customFields.smartTicket'ı her zaman kabul eder;
# GET /api/lookups/taxonomies her zaman yanıt verir; admin CRUD ve
# closure metadata akışları flag'den etkilenmez. Flag yalnız UI
# erişimini açar/kapatır.
# Production'da açmak için: bu env'i true yap + redeploy
# (VITE_* değerleri build sırasında bundle'a inline edilir).
# ─────────────────────────────────────────────────────────────────
VITE_SMART_TICKET_INTAKE_ENABLED=false

# ─────────────────────────────────────────────────────────────────
# Yetkilendirme Yönetimi — Resource/CRUD pilot enforcement.
# false → kayıt işlemi policy'leri sadece tanım/önizleme düzeyindedir.
# true  → seçili pilot API uçlarında deny-only guard devreye girer:
#         case.note create/delete ve case.attachment create/delete.
# Not: Policy allow mevcut role/backend guard'larını GENİŞLETMEZ; yalnız
# mevcut izinli işlemleri daraltabilir. Güvenlik filtresi ve field
# zorunluluğu ayrı fazlardır.
# ─────────────────────────────────────────────────────────────────
AUTHORIZATION_RESOURCE_ENFORCEMENT_ENABLED=false

# ─────────────────────────────────────────────────────────────────
# Yetkilendirme Yönetimi — Field required pilot enforcement.
# false → alan zorunluluğu policy'leri sadece tanım/önizleme düzeyindedir.
# true  → case.close kapsamındaki seçili kapanış alanlarında required
#         policy'leri backend tarafından kontrol edilir:
#         resolutionNote, cancellationReason ve Smart Ticket closure alanları.
# Görünürlük/editable/masked ve diğer formlar ayrı fazlardır.
# ─────────────────────────────────────────────────────────────────
AUTHORIZATION_FIELD_ENFORCEMENT_ENABLED=false

# Frontend Case Detail field UI pilot. false → UI mevcut davranışı korur.
# true → /api/authorization/field-states sonucu Case Detail Detay sekmesinde
#        seçili alanları gizleme/maskeleme/read-only olarak uygular.
VITE_AUTHORIZATION_FIELD_UI_ENFORCEMENT_ENABLED=false

# ─────────────────────────────────────────────────────────────────
# Yetkilendirme Yönetimi — Security filter pilot enforcement.
# false → güvenlik filtresi policy'leri sadece tanım/önizleme düzeyindedir.
# true  → vaka listeleme ve tekil vaka okuma/yazma uçlarında matching
#         securityFilter policy'leri mevcut tenant/rol kapsamını DARALTAN ek
#         where koşulu olarak uygulanır.
#         Allow filter = sadece eşleşen kayıtlar; Deny filter = eşleşen kayıtları
#         hariç tut. Yetki genişletmez, yeni şirket/rol erişimi açmaz.
# Pilot kapsamı: vaka listesi/KPI/yardımcı listeler, tagging-review list/export,
# GET /api/cases/:id ve aynı vaka id'sine bağlı detay/bağlantı/not/dosya
# yardımcı uçları.
# ─────────────────────────────────────────────────────────────────
AUTHORIZATION_SECURITY_FILTER_ENFORCEMENT_ENABLED=false

# ─────────────────────────────────────────────────────────────────
# Cron secret — Vercel Cron jobs için (vercel.json'daki crons config).
# Vercel cron tetiklenince `Authorization: Bearer ${CRON_SECRET}` ekler.
# Production'da güçlü rastgele bir değer (örn. `openssl rand -hex 32`).
# Bu env yoksa cron endpoint'i kapalı (503).
# ─────────────────────────────────────────────────────────────────
CRON_SECRET=replace_with_long_random_string

# ─────────────────────────────────────────────────────────────────
# TCKN HMAC pepper (KVKK — Individual müşteri kayıtları için zorunlu).
# `server/utils/accountValidation.js::hashTckn` plain TCKN'i
# HMAC-SHA256 ile hash'leyip masked (last4) görünüm dışında plaintext
# tutmaz. Pepper bu HMAC'in anahtarıdır.
#
# Production gereksinimi:
#   - 16+ karakterlik random secret (kod ≥16 hane bekliyor;
#     production için `openssl rand -hex 32` önerilir)
#   - Vercel Project Settings → Environment Variables'a girilmeli
#   - Atlanırsa veya 16 haneden kısa olursa Individual müşteri kaydı
#     TCKN ile **create / update** akışlarında 400
#     `tckn_pepper_missing` döner (safe-fail — plain TCKN asla
#     saklanmaz). Sadece `hashTckn()` yazma yolu çağrıldığında
#     fırlatılır; okuma/listeleme bu hata kodunu döndürmez.
#
# Rotation policy: **forward-only**. Yeni TCKN'ler yeni pepper ile
# hash'lenir; eski hash'ler eski pepper'la sealed kalır (HMAC tek
# yönlü). Rotation runbook'u TECHNICAL_DEBT'te (PC-209/PC-315 — OD-023
# karar bekleniyor).
# ─────────────────────────────────────────────────────────────────
TCKN_HASH_PEPPER=replace_with_32_char_random_secret

# ─────────────────────────────────────────────────────────────────
# External KB API key — WR-KB1 + Smart Ticket Phase 2.
# Server-side env (VITE_ prefix YOK; bundle'a inline edilmez).
#
# Per-tenant External KB Settings'te `apiKeySecretName` alanı bu env
# değişkeninin adını tutar; backend `externalKbClient` çağrı sırasında
# `process.env[setting.apiKeySecretName]` ile okur.
#
# **Tipik kullanım**: Admin → Bilgi Bankası Entegrasyonu → şirket için
# Enabled + Bearer auth + apiKeySecretName=EXTERNAL_KB_API_KEY ise bu
# env zorunludur. Aksi durumda KB-bağımlı UI yolları (Smart Ticket
# "KB ile Analiz Et", Çözüm Adımları "AI Önerilen Adımlar Al",
# KnowledgeBasePage analyze) 502 `external_kb_failed` döner ve
# kullanıcıya "External KB çağrısı başarısız oldu" hatası gösterilir.
#
# Birden fazla şirketin farklı KB key'i varsa apiKeySecretName her
# şirket için ayrı isim olabilir (örn. EXTERNAL_KB_API_KEY_UNIVERA);
# o zaman BURADA tek değer değil, her isim için ayrı satır gerekir.
#
# Production'da Vercel → Settings → Environment Variables üzerinden
# set edilmeli; değişiklikten sonra yeni deploy gerekir (process.env
# build/start anında okunur, runtime'da reload edilmez).
# ─────────────────────────────────────────────────────────────────
EXTERNAL_KB_API_KEY=replace_with_external_kb_api_key


# ─────────────────────────────────────────────────────────────────
# Azure DevOps / TFS Entegrasyonu (PR-D1)
# ─────────────────────────────────────────────────────────────────
# Spec: docs/DEVOPS_INTEGRATION.md
#
# server/lib/devopsClient.js TFS REST API'sine Basic auth + PAT ile
# bağlanır. KB modülünden bağımsız (ayrı lib). MVP: tek on-prem tenant;
# Faz 2'de per-tenant DevOpsSetting model.
#
# - TFS_BASE_URL: KOLEKSİYON seviyesi (collection + _apis). Proje "Sirius"
#   URL'ye GİRMEZ — proje bilgisi work item içinde Univera.ProjectName
#   alanından gelir. Work item çağrıları kolleksiyon kapsamında yapılır.
# - TFS_PAT: Personal Access Token — Work Items (Read) + (Write/Manage
#   D2 link/unlink için yeterli; create Faz 2'de). 1 yıl expiry,
#   rotate prosedürü docs/ONPREM_INSTALL.md'ye ek olarak yazılacak.
# - TFS_API_VERSION: On-prem TFS sürümü; PR-D1 connectivity testinde
#   "4.1" doğrulandı. Hedef sunucu farklı sürümdeyse buradan değiştirilir.
# - TFS_TIMEOUT_MS: KB modülünde 120sn default; defect ufak veri,
#   15sn yeterli.
# - TFS_TEST_WORKITEM_ID: scripts/devops-test-get-workitem.js'in
#   örnek olarak çekeceği work item id'si (canlı sunucudan gerçek
#   bir id).
#
# PAT ASLA repo'ya commit'lenmez. .env dosyası gitignore'dadır;
# .env.example yalnız placeholder içerir.
TFS_BASE_URL=https://unitfs.univera.com.tr/tfs/DefaultCollection/_apis
TFS_PAT=replace_with_personal_access_token
# Faz 2.1 follow-up — On-prem TFS Basic auth user+secret bekliyor (boş
# username + PAT → 401). Cloud Azure DevOps PAT-only çalıştığı için
# TFS_USERNAME boş bırakılabilir. Örn: TFS_USERNAME=DOMAIN\user.
# Username SECRET DEĞİL (parola/PAT şifreli; username plain) ama
# log/diag çıktılarında plain gözükmez (sadece "usernameSet" boolean).
TFS_USERNAME=
TFS_API_VERSION=4.1
TFS_TIMEOUT_MS=15000
TFS_TEST_WORKITEM_ID=324813

# DevOps PAT şifreleme anahtarı (Faz 2.1 admin UI için).
# - AES-256-GCM; 32 byte. base64 (44 char) veya hex (64 char) kabul edilir.
# - Anahtarı bir kez üret, sabit tut:
#       openssl rand -base64 32
# - PAT'ın aksine: bu anahtar yıllık rotate edilmez; ops kurulumunda 1 kez set
#   edilir. Rotation = Faz 3.
# - Anahtar yoksa secretCipher LAZY THROW eder (boot crash yok); admin
#   UI'da PAT girişinde 500 hatası gözükür.
# - PAT'lar bu anahtarla DB'de şifreli saklanır; plain text ASLA loglanmaz/
#   GET response'a inmez.
DEVOPS_PAT_ENC_KEY=replace_with_base64_32byte_key

# ─────────────────────────────────────────────────────────────────
# Mail Provider (M1) — feature/mail-provider-ethereal-probe
# ─────────────────────────────────────────────────────────────────
# server/lib/mailProvider.js gönderim katmanı. M1 IT-bağımsız doğrulama:
# `npm run mail:probe` → Ethereal preview URL ile sahte SMTP'den
# gönderim testi. Gerçek mailbox bağlama M3'te (gerçek SMTP/IMAP).
#
# - MAIL_TRANSPORT: ethereal (default) | smtp
#     * ethereal: nodemailer.createTestAccount() ile sahte SMTP; preview URL
#       browser'da gönderilen mesajı gösterir.
#     * smtp: gerçek SMTP (SMTP_* değişkenleri gerekir).
# - MAIL_AUTH: password (default) | oauth2 (sonraki PR; şimdi unsupported)
# - MAIL_FROM: Default gönderen (örn. "Varuna <no-reply@univera.com.tr>")
# - SMTP_HOST/PORT/SECURE/USER/PASS: gerçek SMTP transport için (MAIL_TRANSPORT=smtp).
#   NOT: SMTP_PASS düz env (M1 fallback); per-tenant + secretCipher şifreleme M5'te.
#
# M5 (per-tenant): SMTP/IMAP config Admin UI'da per-company saklanır
# (model ExternalMailSetting). Secret AES-256-GCM ile DB'de şifreli;
# DEVOPS_PAT_ENC_KEY env reuse ediliyor (yukarıdaki bölüm). Mail için
# ayrı bir env key YOK — tek anahtar tüm secret'ları şifreliyor.
# Aşağıdaki SMTP_* env'leri DB satırı yokken backward-compat fallback.
#MAIL_TRANSPORT=ethereal
#MAIL_AUTH=password
#MAIL_FROM=Varuna <no-reply@univera.com.tr>
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_SECURE=false
#SMTP_USER=
#SMTP_PASS=
