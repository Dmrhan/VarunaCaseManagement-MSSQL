# ─────────────────────────────────────────────────────────────────
# Varuna Case Management — environment değişkenleri
# Lokalde .env'e kopyalayıp gerçek değerleri yaz.
# Vercel'de Project Settings → Environment Variables panelinden gir.
# ─────────────────────────────────────────────────────────────────

# OpenAI API key — RUNA AI özellikleri için
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_key_here

# ─────────────────────────────────────────────────────────────────
# Supabase Postgres bağlantısı
# Supabase Dashboard → Project Settings → Database → Connection String
# "Transaction" pooler (port 6543) seç — Vercel serverless için optimal.
# Migration için "Session" pooler (port 5432) DIRECT_URL'a koy.
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ─────────────────────────────────────────────────────────────────
# Supabase — Storage + Auth (BFF)
# Dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ─────────────────────────────────────────────────────────────────
# Supabase Auth — frontend (browser exposed, VITE_ prefix zorunlu)
# anon/publishable key — secret değil, login akışı için browser'a gider
# ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ─────────────────────────────────────────────────────────────────
# Cron secret — Vercel Cron jobs için (vercel.json'daki crons config).
# Vercel cron tetiklenince `Authorization: Bearer ${CRON_SECRET}` ekler.
# Production'da güçlü rastgele bir değer (örn. `openssl rand -hex 32`).
# Bu env yoksa cron endpoint'i kapalı (503).
# ─────────────────────────────────────────────────────────────────
CRON_SECRET=replace_with_long_random_string
