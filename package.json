{
  "name": "varuna-case-management",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,magenta \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch --env-file-if-exists=.env server/index.js",
    "start": "node --env-file-if-exists=.env server/index.js",
    "mail:probe": "node --env-file-if-exists=.env scripts/mail-probe.js",
    "mail:inbound-test": "node --env-file-if-exists=.env scripts/inbound-mail-test.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "deploy:onprem": "node scripts/deploy-onprem.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:auth": "tsx prisma/seedAuth.ts",
    "db:seed:scenarios": "tsx prisma/seedScenarios.ts --confirm-demo-seed",
    "db:seed:full-demo": "node --env-file=.env scripts/seed-full-demo-scenarios.js",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "test:pattern": "node --env-file=.env scripts/test-pattern-alert.js",
    "test:qa": "node --env-file=.env scripts/test-qa-scores.js",
    "devops:test:get": "node --env-file=.env scripts/devops-test-get-workitem.js",
    "smoke:data-contracts": "node --env-file=.env scripts/smoke-data-contracts.js",
    "smoke:help-content": "node scripts/smoke-help-content.js",
    "smoke:ai-telemetry": "node --env-file=.env scripts/smoke-ai-telemetry.js",
    "smoke:authorization-registry": "node scripts/smoke-authorization-registry-static.js",
    "smoke:release": "node --env-file=.env scripts/smoke-release-regression.js",
    "smoke:pr5-static-guards": "node scripts/smoke-pr5-static-guards.js",
    "smoke:account-tckn-search": "node --env-file=.env scripts/smoke-account-tckn-search.js",
    "smoke:admin-create-phase5c": "node --env-file=.env scripts/smoke-admin-create-phase5c.js",
    "smoke:account-id-standard": "node --env-file=.env scripts/smoke-account-id-standardization.js",
    "smoke:account-phone-slots-import": "node --env-file=.env scripts/smoke-account-phone-slots-import.js",
    "smoke:import-integrity": "node --env-file=.env scripts/smoke-import-integrity-phone-tax.js"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.19.3",
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "httpntlm": "^1.8.13",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.13.5",
    "lucide-react": "^0.469.0",
    "mailparser": "^3.9.11",
    "mssql": "^12.5.5",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "openai": "^6.35.0",
    "pg": "^8.21.0",
    "prisma": "^6.19.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "sqlite-vec": "^0.1.9",
    "tsx": "^4.21.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
