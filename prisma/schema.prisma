// ═══════════════════════════════════════════════════════════════════
// WR-D4 Phase 1 — Resolution Approval Foundation
// Internal approval governance before a case can be closed when a
// matching ResolutionApprovalPolicy exists. No customer communication
// in Phase 1 — that lives in Phase 2+ (NotificationRule/Template/
// Dispatch). See docs/planning_cards/WR-D4-D3-...md §16 Phase 1.
// ═══════════════════════════════════════════════════════════════════

/// WR-D4 — Per-tenant policy: when does a case require approval before
/// closing, and who approves it. Phase 1 supports companyId scope +
/// optional matchScope JSON filters (category/subCategory/priority/
/// supportLevel/teamId). Soft-disable via isActive=false; hard delete
/// not supported (audit trail).
model ResolutionApprovalPolicy {
  id                String   @id @default(cuid()) @db.NVarChar(450)
  companyId         String   @db.NVarChar(450)
  name              String   @db.NVarChar(Max)
  description       String?  @db.NVarChar(Max)
  isActive          Boolean  @default(true)
  /// Lower number wins on match. Default 100.
  sortOrder         Int      @default(100)
  /// { category?, subCategory?, priority?, supportLevel?, teamId? }
  /// All null = match-all. App-layer JSON filtering (MSSQL portable).
  matchScope        String   @db.NVarChar(Max) // json
  approverType      String   @db.NVarChar(50) // enum:ApproverType
  /// Required when approverType=SpecificPerson; else null.
  approverPersonId  String?  @db.NVarChar(450)
  /// Default false. When false, the submitter cannot also be the
  /// resolved approver (submit returns 400 self_approval_blocked).
  allowSelfApprove  Boolean  @default(false)
  rejectionBehavior String   @default("ReturnToAssignee") @db.NVarChar(50) // enum:RejectionBehavior
  createdAt         DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt         DateTime @updatedAt
  createdByUserId   String?  @db.NVarChar(450)

  company        Company @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approverPerson Person? @relation("ResolutionApprovalPolicyApprover", fields: [approverPersonId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  approvals CaseResolutionApproval[]

  @@index([companyId, isActive])
  @@index([companyId, sortOrder])
}

/// WR-D4 — A single approval cycle for a case. Immutable history: a
/// rejected approval stays; reopen creates a new row. Snapshot fields
/// (policyNameSnapshot) preserve audit even when the policy is later
/// edited or deactivated.
model CaseResolutionApproval {
  id                       String    @id @default(cuid()) @db.NVarChar(450)
  caseId                   String    @db.NVarChar(450)
  companyId                String    @db.NVarChar(450)
  policyId                 String?   @db.NVarChar(450)
  policyNameSnapshot       String    @db.NVarChar(Max)
  state                    String    @default("Pending") @db.NVarChar(50) // enum:ApprovalState
  submittedByUserId        String    @db.NVarChar(450)
  submittedAt              DateTime  @default(dbgenerated("sysutcdatetime()"))
  /// Agent's resolution summary text. Becomes audit at submit time.
  resolutionSummary        String    @db.NVarChar(Max)
  /// Optional draft message intended for the customer. Phase 1: not
  /// sent anywhere; surfaces in approver's preview only.
  customerMessageDraft     String?   @db.NVarChar(Max)
  /// Snapshot of the resolved approver at submit time. Used to filter
  /// approver inboxes and to verify authority on approve/reject.
  expectedApproverPersonId String?   @db.NVarChar(450)
  decidedByUserId          String?   @db.NVarChar(450)
  decidedAt                DateTime?
  /// Required when state=Rejected. Free-text reason shown to submitter.
  rejectionReason          String?   @db.NVarChar(Max)
  createdAt                DateTime  @default(dbgenerated("sysutcdatetime()"))
  updatedAt                DateTime  @updatedAt

  case             Case                      @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  policy           ResolutionApprovalPolicy? @relation(fields: [policyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  expectedApprover Person?                   @relation("CaseResolutionApprovalApprover", fields: [expectedApproverPersonId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([caseId])
  @@index([companyId, state])
  @@index([expectedApproverPersonId, state])
  @@index([caseId, state])
}

// CaseNotification — bildirim logları
model CaseNotification {
  id        String    @id @default(cuid()) @db.NVarChar(450)
  caseId    String    @db.NVarChar(450)
  companyId String    @db.NVarChar(450)
  eventType String    @db.NVarChar(255) // "CaseAssigned", "SLAWarning", "SLAViolation", vb.
  channel   String    @db.NVarChar(50) // enum:NotificationChannel
  recipient String    @db.NVarChar(255) // Person.id veya email
  payload   String?   @db.NVarChar(Max) // Bildirim içeriği snapshot // json
  sentAt    DateTime  @default(dbgenerated("sysutcdatetime()"))
  readAt    DateTime?

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([caseId])
  @@index([companyId])
  @@index([recipient, readAt])
}

// KnowledgeSource — Faz 1.5 Madde 6.
// "AI neye bakıyor?" sorusunu şeffaf hale getiren admin kayıt defteri.
// Ne otomatik ingestion ne embedding — sadece bilgi kaynağı kataloğu.
// `contentCount` admin'in rapor ettiği veya seed sırasında ilgili tablodan
// (Case, SLAPolicy, ChecklistTemplate, CategoryDef) sayılan değer.
model KnowledgeSource {
  id           String   @id @default(cuid()) @db.NVarChar(450)
  companyId    String   @db.NVarChar(450)
  name         String   @db.NVarChar(Max)
  sourceType   String   @db.NVarChar(50) // enum:KnowledgeSourceType
  contentCount Int      @default(0)
  description  String?  @db.NVarChar(Max)
  isActive     Boolean  @default(true)
  lastUpdated  DateTime @default(dbgenerated("sysutcdatetime()"))
  createdAt    DateTime @default(dbgenerated("sysutcdatetime()"))

  @@index([companyId])
}

// QAScoreLog — Faz 1.5 Madde 4 (Smart QA Lite).
// Her kapatılmış vakaya bir kez AI 3 kriter (empati/netlik/hız) puanlar.
// Case tablosunda da snapshot tutulur (qaXxxScore alanları); bu tablo ek
// audit + per-agent rapor için. caseId @unique → tek vaka tek log.
model QAScoreLog {
  id        String   @id @default(cuid()) @db.NVarChar(450)
  caseId    String   @unique @db.NVarChar(450)
  companyId String   @db.NVarChar(450)
  scoredAt  DateTime @default(dbgenerated("sysutcdatetime()"))
  empathy   Int
  clarity   Int
  speed     Int
  feedback  String?  @db.NVarChar(Max)

  @@index([companyId])
  @@index([companyId, scoredAt])
}

// PatternAlert — Faz 1.5 Madde 5 (Bekçi rolü §5.5 örüntü tespiti).
// Cron her 15 dk son 60 dk'daki vakaları (companyId, category) ile gruplar;
// 5+ vaka varsa active alarm yarat. Yönetici dismiss eder. Read-only mode:
// otomatik parent vaka açma yok — sadece sinyal.
model PatternAlert {
  id             String    @id @default(cuid()) @db.NVarChar(450)
  companyId      String    @db.NVarChar(450)
  category       String    @db.NVarChar(Max)
  caseCount      Int
  windowMinutes  Int       @default(60)
  detectedAt     DateTime  @default(dbgenerated("sysutcdatetime()"))
  caseIds        String    @db.NVarChar(Max) // string[] — tetikleyici vaka id'leri // json
  /// status values: 'active' | 'dismissed' | 'known_issue' (PR-2 ile 3 değer).
  /// known_issue: bilinen sorun — dismiss değil, ayrı raporlanır.
  status         String    @default("active") @db.NVarChar(50) // enum:PatternAlertStatus
  dismissedBy    String?   @db.NVarChar(Max) // User.id
  dismissedAt    DateTime?
  /// PR-3 — RUNA-tarzı AI hipotezi (commentary-only). JSON string:
  /// { hypothesis: string, suggestedAction: string }.
  /// LAZY: kart açılışında veya "AI hipotezi" tıklandığında üretilir + saklanır.
  /// Cache TTL: aiHypothesisAt < now-24h ise stale → yeniden üretilir.
  /// AI fail durumunda null kalır; kart AI kutusu olmadan çalışır (graceful degrade).
  aiHypothesis   String?   @db.NVarChar(Max) // json
  aiHypothesisAt DateTime?

  @@index([companyId])
  @@index([companyId, detectedAt])
  @@index([status])
}

// AIUsageLog — Faz 1.5 Madde 7.
// Her AI endpoint çağrısı için bir log satırı: kabul/red, yanıt süresi,
// token sayısı, kullanıcı + vaka referansı. ROI panosu (Analitik → AI Kullanımı)
// bu logdan agrege istatistik üretir. companyId zorunlu — multi-tenant scope.
//
// caseId/userId nullable (örn. dashboard önizlemesi gibi vaka-bağımsız çağrılar
// için), accepted nullable (kullanıcı henüz uygula/yoksay tıklamadı), tokenCount
// nullable (provider yanıtında token sayısı dönmeyebilir).
model AIUsageLog {
  id             String   @id @default(cuid()) @db.NVarChar(450)
  companyId      String   @db.NVarChar(450)
  endpoint       String   @db.NVarChar(255) // 'suggest-category' | 'draft-resolution' | 'churn-conversion' | 'qa-score' | 'other'
  caseId         String?  @db.NVarChar(450)
  userId         String?  @db.NVarChar(450)
  accepted       Boolean? // null = kullanıcı kararı bekliyor (uygula/yoksay)
  responseTimeMs Int?
  tokenCount     Int?
  createdAt      DateTime @default(dbgenerated("sysutcdatetime()"))

  @@index([companyId])
  @@index([companyId, createdAt])
  @@index([endpoint])
}

// CaseMention — Faz 1.5 Madde 3.
// Notlarda @mention edilen kullanıcılar için audit + bildirim kaydı.
// noteId CaseNote.id; not silinirse mention satırı kalır (raporlama/audit).
// companyId zorunlu — multi-tenant scope filter (top-level "kullanıcının
// PARAM mentionları" sorgusu için JOIN gerektirmez).
//
// Spec §4'teki `sourceType` (note | comment_reply) bu fazda atlanıyor:
// yalnızca CaseNote desteği. comment-reply geldiğinde tablo yapısı
// `sourceType + sourceId` olarak yeniden modellenir (migration ile).
model CaseMention {
  id              String    @id @default(cuid()) @db.NVarChar(450)
  caseId          String    @db.NVarChar(450)
  noteId          String    @db.NVarChar(450)
  companyId       String    @db.NVarChar(450)
  mentionedUserId String    @db.NVarChar(450) // User.id — auth identity (UserCompany erişim sahibi)
  mentionedBy     String    @db.NVarChar(Max) // User.id — etiketleyen kullanıcı
  seenAt          DateTime? // null = henüz görülmedi → header bell badge
  createdAt       DateTime  @default(dbgenerated("sysutcdatetime()"))

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([caseId])
  @@index([mentionedUserId])
  @@index([companyId])
}

// AISuggestion — AI önerilerinin audit kaydı
model AISuggestion {
  id              String   @id @default(cuid()) @db.NVarChar(450)
  caseId          String   @db.NVarChar(450)
  companyId       String   @db.NVarChar(450)
  suggestionType  String   @db.NVarChar(255) // "category", "priority", "resolution", vb.
  suggestedValue  String   @db.NVarChar(Max)
  confidenceScore Float?
  accepted        Boolean? // null=henüz değerlendirilmedi, true=uygula, false=yoksay
  rejectReason    String?  @db.NVarChar(Max)
  createdAt       DateTime @default(dbgenerated("sysutcdatetime()"))

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([caseId])
  @@index([companyId])
}

// CaseTransfer — FAZ 2 §20.2 (Vaka Aktarımı).
// Bir vaka takım → takım veya kişi → kişi devredildiğinde tam audit izi
// tutulur. AI önerisi varsa (suggestedTeam + reasonCode + confidence)
// kabul edildi/edilmedi telemetrisi için snapshot alınır.
//
// transferCount Case üzerinde @default(0); her satır ekleme +1 ile birlikte
// gider. 2+ olduğunda supervisor notification + kök neden analizi tetikler.
model CaseTransfer {
  id        String @id @default(cuid()) @db.NVarChar(450)
  caseId    String @db.NVarChar(450)
  companyId String @db.NVarChar(450)

  fromTeamId   String? @db.NVarChar(450)
  toTeamId     String  @db.NVarChar(450)
  fromPersonId String? @db.NVarChar(450)
  toPersonId   String? @db.NVarChar(450)

  reason        String   @db.NVarChar(Max)
  reasonCode    String?  @db.NVarChar(255)
  transferredBy String   @db.NVarChar(Max)
  transferredAt DateTime @default(dbgenerated("sysutcdatetime()"))

  // AI önerisi snapshot (uygulandı/yok sayıldı analizi için)
  aiSuggestedTeamId String? @db.NVarChar(450)
  aiSuggestedReason String? @db.NVarChar(Max)
  aiReasonCode      String? @db.NVarChar(255)
  aiConfidence      Float?

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([caseId])
  @@index([companyId])
  @@index([companyId, transferredAt])
}

// CaseTaggingReview — Vaka Etiket Doğrulama Ekranı (bilgi bankası seed'i için
// audit). Supervisor/Admin/SystemAdmin her vakanın açılış (5 alan) ve kapanış
// (4 alan, sadece Smart Ticket + Çözüldü vakalarda dolu) etiketini ALAN
// BAZINDA Doğru/Yanlış/Belirsiz olarak işaretler. Original{Code,Label} snapshot
// alanları create sırasında Case.customFields'tan KOPYALANIR ve bir daha
// değişmez — bu kayıtlar bilgi bankası doğrulama/eğitim veri setini besler,
// dolayısıyla vaka arşivlenip silinse bile bağımsız kalmalı. Corrected{Code,Label}
// sadece kendi taxonomyType'ına ait TaxonomyDef'ten seçilir (server-side
// batch validasyon — caseRepository.upsertTaggingReview). caseId @unique →
// tek vaka tek kayıt, upsert pattern (QAScoreLog ile aynı desen — concurrency
// token yok, son yazan kazanır). reviewerId/reviewerName/reviewedAt backend'de
// (req.user) stamplenir, client body'den asla okunmaz.
model CaseTaggingReview {
  id        String @id @default(cuid()) @db.NVarChar(450)
  caseId    String @unique @db.NVarChar(450)
  companyId String @db.NVarChar(450)

  openingPlatformOriginalCode   String? @db.NVarChar(255)
  openingPlatformOriginalLabel  String? @db.NVarChar(Max)
  openingPlatformVerdict        String? @db.NVarChar(50) // enum:TaggingVerdict
  openingPlatformCorrectedCode  String? @db.NVarChar(255)
  openingPlatformCorrectedLabel String? @db.NVarChar(Max)

  openingBusinessProcessOriginalCode   String? @db.NVarChar(255)
  openingBusinessProcessOriginalLabel  String? @db.NVarChar(Max)
  openingBusinessProcessVerdict        String? @db.NVarChar(50) // enum:TaggingVerdict
  openingBusinessProcessCorrectedCode  String? @db.NVarChar(255)
  openingBusinessProcessCorrectedLabel String? @db.NVarChar(Max)

  openingOperationTypeOriginalCode   String? @db.NVarChar(255)
  openingOperationTypeOriginalLabel  String? @db.NVarChar(Max)
  openingOperationTypeVerdict        String? @db.NVarChar(50) // enum:TaggingVerdict
  openingOperationTypeCorrectedCode  String? @db.NVarChar(255)
  openingOperationTypeCorrectedLabel String? @db.NVarChar(Max)

  openingAffectedObjectOriginalCode   String? @db.NVarChar(255)
  openingAffectedObjectOriginalLabel  String? @db.NVarChar(Max)
  openingAffectedObjectVerdict        String? @db.NVarChar(50) // enum:TaggingVerdict
  openingAffectedObjectCorrectedCode  String? @db.NVarChar(255)
  openingAffectedObjectCorrectedLabel String? @db.NVarChar(Max)

  openingImpactOriginalCode   String? @db.NVarChar(255)
  openingImpactOriginalLabel  String? @db.NVarChar(Max)
  openingImpactVerdict        String? @db.NVarChar(50) // enum:TaggingVerdict
  openingImpactCorrectedCode  String? @db.NVarChar(255)
  openingImpactCorrectedLabel String? @db.NVarChar(Max)

  closingRootCauseGroupOriginalCode   String? @db.NVarChar(255)
  closingRootCauseGroupOriginalLabel  String? @db.NVarChar(Max)
  closingRootCauseGroupVerdict        String? @db.NVarChar(50) // enum:TaggingVerdict
  closingRootCauseGroupCorrectedCode  String? @db.NVarChar(255)
  closingRootCauseGroupCorrectedLabel String? @db.NVarChar(Max)

  closingRootCauseDetailOriginalCode   String? @db.NVarChar(255)
  closingRootCauseDetailOriginalLabel  String? @db.NVarChar(Max)
  closingRootCauseDetailVerdict        String? @db.NVarChar(50) // enum:TaggingVerdict
  closingRootCauseDetailCorrectedCode  String? @db.NVarChar(255)
  closingRootCauseDetailCorrectedLabel String? @db.NVarChar(Max)

  closingResolutionTypeOriginalCode   String? @db.NVarChar(255)
  closingResolutionTypeOriginalLabel  String? @db.NVarChar(Max)
  closingResolutionTypeVerdict        String? @db.NVarChar(50) // enum:TaggingVerdict
  closingResolutionTypeCorrectedCode  String? @db.NVarChar(255)
  closingResolutionTypeCorrectedLabel String? @db.NVarChar(Max)

  closingPermanentPreventionOriginalCode   String? @db.NVarChar(255)
  closingPermanentPreventionOriginalLabel  String? @db.NVarChar(Max)
  closingPermanentPreventionVerdict        String? @db.NVarChar(50) // enum:TaggingVerdict
  closingPermanentPreventionCorrectedCode  String? @db.NVarChar(255)
  closingPermanentPreventionCorrectedLabel String? @db.NVarChar(Max)

  note String? @db.NVarChar(Max)

  reviewerId   String?   @db.NVarChar(450)
  reviewerName String?   @db.NVarChar(Max)
  reviewedAt   DateTime?

  createdAt DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt DateTime @updatedAt

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([companyId])
}

// CaseWatcher — FAZ 2 Collab. Vaka takipçileri; vakada değişiklik olunca
// (status, atama, not vs.) CaseNotification yazılır → bell badge + watcher
// inbox (ileri faz). Bir kullanıcı bir vakaya bir kez watcher olabilir;
// addedBy = self-join veya başkası (Supervisor) tarafından eklendiyse User.id.
// companyId zorunlu — multi-tenant scope (top-level "benim watcher'larım"
// sorgusu için JOIN gerektirmez).
model CaseWatcher {
  id        String   @id @default(cuid()) @db.NVarChar(450)
  caseId    String   @db.NVarChar(450)
  userId    String   @db.NVarChar(450)
  companyId String   @db.NVarChar(450)
  addedBy   String   @db.NVarChar(Max)
  addedAt   DateTime @default(dbgenerated("sysutcdatetime()"))

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([caseId, userId])
  @@index([userId])
  @@index([companyId])
  @@index([caseId])
}

// CaseLink — FAZ 2 Collab. Vakalar arası bağlantı (3 tip):
//   - Related:   genel ilişkili (yumuşak referans)
//   - Duplicate: aynı sorun (symmetric — A↔B her iki yön de yazılır)
//   - Parent:    bu vaka, hedef vakanın parçası (asymmetric — A → B = A is child)
//
// Symmetric davranış Duplicate için route layer'ında ele alınır
// (her iki yönde de satır yazılır). Schema'da @@unique([caseId,
// linkedCaseId, linkType]) ile dublike koruma; aynı yönde aynı tip iki
// kez eklenemez.
//
// companyId zorunlu — multi-tenant scope. Cross-tenant link route layer'ında
// reddedilir (kaynak ve hedef vakanın companyId'leri eşit olmalı).
model CaseLink {
  id           String   @id @default(cuid()) @db.NVarChar(450)
  caseId       String   @db.NVarChar(450)
  linkedCaseId String   @db.NVarChar(450)
  linkType     String   @db.NVarChar(50) // enum:CaseLinkType
  companyId    String   @db.NVarChar(450)
  createdBy    String   @db.NVarChar(Max)
  createdAt    DateTime @default(dbgenerated("sysutcdatetime()"))

  case       Case @relation("CaseLinkSource", fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  // MSSQL: Case'e iki FK (kaynak+hedef) çift cascade path yaratır — hedef taraf
  // NoAction; hedef case silinirken CaseLink satırları uygulama katmanında silinmeli.
  linkedCase Case @relation("CaseLinkTarget", fields: [linkedCaseId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([caseId, linkedCaseId, linkType])
  @@index([caseId])
  @@index([linkedCaseId])
  @@index([companyId])
}

// ─────────────────────────────────────────────────────────────────
// WR-A8 — Data Integration Studio (Account import audit)
// ─────────────────────────────────────────────────────────────────
//
// ImportJob + ImportJobRow ham satır, normalize edilmiş satır, eski/yeni alan
// snapshot'larını saklar. Rollback yetkisi için yeterli denetim verisi taşır.
// Şirket bazlı izole; Admin yalnızca kendi şirketinin job'larını görür/işler.

model ImportJob {
  id                  String    @id @default(cuid()) @db.NVarChar(450)
  companyId           String    @db.NVarChar(450)
  /// Phase 1: "account". İleride "case", "product" vb. eklenebilir.
  targetType          String    @default("account") @db.NVarChar(255)
  /// "file" | "api"
  sourceType          String    @db.NVarChar(255)
  /// API kaynağı için kullanıcı tanımlı isim ya da dosya adı.
  sourceName          String?   @db.NVarChar(Max)
  /// API kaynağı için (sadece host + path, secret'sız). Audit/debug için.
  sourceUrlMasked     String?   @db.NVarChar(Max)
  fileName            String?   @db.NVarChar(Max)
  dataPath            String?   @db.NVarChar(Max)
  /// Hedef şema versiyonu (commit zamanı doğrulanır).
  targetSchemaVersion String    @db.NVarChar(Max)
  /// "draft" | "validated" | "running" | "partial" | "completed" | "failed" | "rolled_back" | "rollback_partial"
  status              String    @default("draft") @db.NVarChar(255)
  totalRows           Int       @default(0)
  createCount         Int       @default(0)
  updateCount         Int       @default(0)
  skippedCount        Int       @default(0)
  errorCount          Int       @default(0)
  warningCount        Int       @default(0)
  /// Auto-map önerileri, mapping snapshot, dry-run özeti vb.
  summaryJson         String?   @db.NVarChar(Max) // json
  /// WR-A8 Phase 2b — Customer 360 per-entity create/update/skip/error
  /// breakdown. account targetType için null kalır (Phase 1 scalar count'lar
  /// yeterli). Customer 360 için: { account: {...}, accountCompany: {...}, ... }.
  entityCountsJson    String?   @db.NVarChar(Max) // json
  createdByUserId     String?   @db.NVarChar(450)
  createdAt           DateTime  @default(dbgenerated("sysutcdatetime()"))
  startedAt           DateTime?
  completedAt         DateTime?
  rolledBackAt        DateTime?
  rolledBackByUserId  String?   @db.NVarChar(450)
  /// Phase D-tick — concurrent-tick lease. Bir tick acquire ettiğinde
  /// leaseTickId set olur; release veya stale TTL (2dk) sonra null'a
  /// döner. Sadece customer360 tick path'i yazar; Phase 1 import'ta hep
  /// null. Additive + nullable: mevcut tüm satırlar dokunulmaz.
  leaseTickId         String?   @db.NVarChar(450)
  leaseAt             DateTime?
  heartbeatAt         DateTime?

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  rows    ImportJobRow[]

  @@index([companyId])
  @@index([companyId, createdAt])
  @@index([status])
}

model ImportJobRow {
  id              String   @id @default(cuid()) @db.NVarChar(450)
  importJobId     String   @db.NVarChar(450)
  rowNumber       Int
  /// "create" | "update" | "skip" | "error"
  action          String   @default("skip") @db.NVarChar(Max)
  /// "pending" | "processing" | "created" | "updated" | "skipped" | "error" | "rolled_back" | "rollback_error"
  status          String   @default("pending") @db.NVarChar(255)
  /// WR-A8 Phase 2b — Customer 360 satırı hangi entity'ye ait:
  /// "account" | "accountCompany" | "accountContact" | "accountAddress" | "accountProject".
  /// Phase 1 satırları için null (legacy account-only); Phase 2b satırları için zorunlu.
  entityType      String?  @db.NVarChar(255)
  /// Parent satırın rowNumber'ı (child entity'ler için audit/UI navigation).
  /// Yalnız Customer 360 child row'larında doludur (account null bırakır).
  parentRowNumber Int?
  /// Relationship resolve için kullanılan key snapshot'ı ("vkn:1234567890",
  /// "companyCode:COMP-UNIVERA" vb.).
  relationshipKey String?  @db.NVarChar(Max)
  /// Hangi Account'a denk geldi (update yolu) ya da yeni oluşturulan Account ID.
  /// Phase 1 ile geriye uyumluluk: account row'ları için doludur.
  accountId       String?  @db.NVarChar(450)
  /// WR-A8 Phase 2b — polymorphic kayıt ID'si. accountId zaten account satırları
  /// için doluyor; non-account entity'ler (Contact/Address/Project/AC) için
  /// recordId Prisma kaydının id'sini taşır.
  recordId        String?  @db.NVarChar(450)
  /// Match key kullanıldı mı (VKN). Audit için.
  matchKey        String?  @db.NVarChar(Max)
  errorsJson      String?  @db.NVarChar(Max) // json
  warningsJson    String?  @db.NVarChar(Max) // json
  /// Ham satır (kaynak alan adlarıyla).
  rawJson         String?  @db.NVarChar(Max) // json
  /// Normalize edilmiş satır (target field key'lerle).
  normalizedJson  String?  @db.NVarChar(Max) // json
  /// Update öncesi entity snapshot (rollback için).
  beforeJson      String?  @db.NVarChar(Max) // json
  /// Update/create sonrası entity snapshot.
  afterJson       String?  @db.NVarChar(Max) // json
  createdAt       DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt       DateTime @updatedAt

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([importJobId])
  @@index([importJobId, status])
  @@index([importJobId, entityType])
  @@index([accountId])
  @@index([recordId])
}

// ═══════════════════════════════════════════════════════════════════
// WR-D4/D3 Phase 2 — Notification Rule Engine
// ═══════════════════════════════════════════════════════════════════
//
// Three new models added to model rule-based notifications without
// any active external sending:
//
//   - NotificationRule:     event → audience + template + channel + mode
//   - NotificationTemplate: subject/body with {{mustache}} variables
//   - NotificationDispatch: immutable audit row per rule fire (snapshot)
//
// Active delivery (Phase 4) is intentionally out of scope here. The
// `Active` value exists in DispatchMode for forward compatibility, but
// the API blocks creating rules with `mode='Active'` until Phase 4.
//
// MSSQL portability: enums are Prisma-managed (string + check constraint
// in MSSQL provider). Json fields = NVARCHAR(MAX). No PG-specific
// features. App-layer JSON filtering only (no JSON_VALUE queries).
//
// See docs/planning_cards/WR-D4-D3-RESOLUTION-APPROVAL-NOTIFICATION-RULES.md
// §5, §9, §11, §16.3 (Phase 2).

/// WR-D4 Phase 2 — A rule maps an event + matching conditions to an
/// audience + template + channel. Tenant-scoped. Soft-disable via
/// isActive=false (hard delete breaks dispatch audit references).
model NotificationRule {
  id          String  @id @default(cuid()) @db.NVarChar(450)
  companyId   String  @db.NVarChar(450)
  name        String  @db.NVarChar(Max)
  description String? @db.NVarChar(Max)
  isActive    Boolean @default(true)
  sortOrder   Int     @default(100)

  /// Event identifier. Free-string for forward compat. Phase 2 values:
  /// 'resolution_submitted', 'resolution_approved', 'resolution_rejected',
  /// 'case_closed', 'case_reopened'.
  event String @db.NVarChar(100)

  /// Optional JSON filter applied at scan time. Whitelist: category,
  /// subCategory, priority, supportLevel, teamId. Empty {} = no filter,
  /// only valid when isMatchAll=true (admin must explicitly opt in).
  conditions String @db.NVarChar(Max) // json

  /// Safety guard: when conditions={} the admin must check "Match every
  /// case" explicitly. Prevents accidental broadcast rules.
  isMatchAll Boolean @default(false)

  /// Audience definition (1-N rows in same rule). Each item:
  /// `{ type: 'assignee'|'team_lead'|'supervisor'|'admin'|'customer_primary_contact'|'static_email', targetValue?: string }`
  audience String @db.NVarChar(Max) // json

  /// FK to NotificationTemplate. Required — every rule renders a message.
  templateId String @db.NVarChar(450)

  channel String @db.NVarChar(50) // enum:DispatchChannel
  mode    String @default("LogOnly") @db.NVarChar(50) // enum:DispatchMode

  /// Idempotency window in minutes. Same (event, caseId, audienceIdentifier,
  /// templateId) within this window → suppressed dispatch.
  suppressDuplicateWithinMinutes Int?

  /// Per-rule per-hour cap. App-layer SQL count check at dispatch time.
  rateLimitPerHour Int?

  createdAt       DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt       DateTime @updatedAt
  createdByUserId String?  @db.NVarChar(450)

  company    Company                @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  template   NotificationTemplate   @relation(fields: [templateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dispatches NotificationDispatch[]

  @@index([companyId, event, isActive])
  @@index([companyId, sortOrder])
  @@index([templateId])
}

/// WR-D4 Phase 2 — Reusable message templates. Subject + body with
/// {{mustache}} variables resolved at dispatch time. Snapshot of the
/// rendered content is stored on NotificationDispatch so template
/// edits never rewrite history.
model NotificationTemplate {
  id          String  @id @default(cuid()) @db.NVarChar(450)
  companyId   String  @db.NVarChar(450)
  /// Stable key (e.g. 'approval_pending_to_lead'). Unique per tenant.
  key         String  @db.NVarChar(100)
  name        String  @db.NVarChar(Max)
  description String? @db.NVarChar(Max)

  /// Phase 2 = always 'tr'. Phase 6 (i18n) introduces multi-language.
  language String @default("tr") @db.NVarChar(Max)

  subjectTemplate String @db.NVarChar(Max)
  bodyTemplate    String @db.NVarChar(Max)

  /// 'plain' or 'html'. Phase 2 default 'plain' (operator copies to
  /// their mail client; HTML preview is for visual reference).
  format String @default("plain") @db.NVarChar(Max)

  /// UI badge — when true, rule using this template is flagged as
  /// "customer-facing" so the admin double-checks audience.
  isCustomerFacing Boolean @default(false)

  /// Declared variables (e.g. ['case.number','account.name']). Preview
  /// flags when subject/body references something NOT in this list.
  requiredVariables String @db.NVarChar(Max) // json

  /// Bumped on every save. Stamped on dispatch as templateVersionSnapshot.
  version Int @default(1)

  isActive Boolean @default(true)

  createdAt       DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt       DateTime @updatedAt
  createdByUserId String?  @db.NVarChar(450)

  company    Company                @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rules      NotificationRule[]
  dispatches NotificationDispatch[]

  @@unique([companyId, key])
  @@index([companyId, isActive])
}

/// WR-D4 Phase 2 — Immutable audit row per rule fire. Snapshot fields
/// freeze the rendered content so template/rule edits never rewrite
/// history. Manual confirmation stamps `confirmedByUserId`/`confirmedAt`
/// + free-text `deliveryNote` (required at API layer).
model NotificationDispatch {
  id        String @id @default(cuid()) @db.NVarChar(450)
  caseId    String @db.NVarChar(450)
  companyId String @db.NVarChar(450)

  event                   String  @db.NVarChar(100)
  ruleId                  String? @db.NVarChar(450)
  ruleNameSnapshot        String  @db.NVarChar(Max)
  templateId              String? @db.NVarChar(450)
  templateKeySnapshot     String  @db.NVarChar(Max)
  templateVersionSnapshot Int

  /// Resolved audience identity. `audienceType` is the rule audience kind
  /// ('assignee', 'customer_primary_contact', etc.); `audienceIdentifier`
  /// is the resolved value (personId, email, or 'unresolved').
  audienceType       String @db.NVarChar(255)
  audienceIdentifier String @db.NVarChar(Max)

  channel String @db.NVarChar(50) // enum:DispatchChannel
  mode    String @db.NVarChar(50) // enum:DispatchMode
  state   String @default("Pending") @db.NVarChar(50) // enum:DispatchState

  /// Rendered final subject + body — written at dispatch creation.
  snapshotSubject String @db.NVarChar(Max)
  snapshotBody    String @db.NVarChar(Max)

  /// When state=Suppressed: 'duplicate_within_window' / 'rate_limited' /
  /// 'no_channel' / 'customer_opted_out' / 'audience_unresolvable'.
  suppressionReason String? @db.NVarChar(Max)

  /// Idempotency key for the dedup partial unique index. Format:
  /// `${companyId}:${event}:${caseId}:${audienceIdentifier}:${templateId}:${windowBucket}`
  idempotencyKey String? @db.NVarChar(255)

  /// Manual confirmation fields (mode=Manual).
  confirmedByUserId String?   @db.NVarChar(450)
  confirmedAt       DateTime?
  /// Required at API layer when transitioning to mode=Manual / state=Sent.
  deliveryNote      String?   @db.NVarChar(Max)

  /// Phase 4 active delivery fields. M4 (mail outbound) → dispatchedAt
  /// = sent timestamp; providerMessageId = mailProvider'ın döndürdüğü
  /// SMTP Message-ID (round-trip threading için).
  dispatchedAt      DateTime?
  failureReason     String?   @db.NVarChar(Max)
  attempts          Int       @default(0)
  /// M4 — mailProvider sendMail başarısı sonrası dolar. Round-trip
  /// threading için (önceki dispatch'in providerMessageId'si
  /// In-Reply-To/References header'ına geçer).
  providerMessageId String?   @db.NVarChar(Max)

  createdAt DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt DateTime @updatedAt

  case       Case                  @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  company    Company               @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rule       NotificationRule?     @relation(fields: [ruleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  template   NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// M6.1 — Active+email dispatch'lerin paralel CaseEmail satırı (varsa).
  caseEmails CaseEmail[]

  @@unique([idempotencyKey], map: "NotificationDispatch_idempotencyKey_unique")
  @@index([caseId, createdAt(sort: Desc)])
  @@index([companyId, event, createdAt(sort: Desc)])
  @@index([companyId, state])
}

/// Mail M6.1 — Vaka İçi E-Posta thread satırı.
///
/// Bu model tek bir mail'i (gelen ya da giden) saklar. Vaka kapanana
/// kadar müşteri ile karşılıklı mailleşme bu satırlar üzerinde sürer;
/// Case Detail "İletişim" sekmesindeki MailThread bu modelden beslenir.
///
/// Plan referansı: docs/M6-email-in-case-plan.md Bölüm 4.
///
/// KAYNAKLAR (source):
///  - 'imap_intake'         → IMAP polling (M3) sonrası inbound parse
///  - 'manual_send'         → Agent composer (M6.2)
///  - 'notification_dispatch' → M4 outbound dispatch (paralel kayıt)
///
/// Dedup: @@unique([companyId, messageId]) — IMAP retry idempotency +
/// outbound double-send guard. messageId nullable çünkü intake parse
/// her zaman başaramayabilir; dedup-without-id durumu manuel kabul.
model CaseEmail {
  id        String @id @default(cuid()) @db.NVarChar(450)
  caseId    String @db.NVarChar(450)
  companyId String @db.NVarChar(450)

  /// 'inbound' | 'outbound'
  direction String @db.NVarChar(20)

  /// 'imap_intake' | 'manual_send' | 'notification_dispatch'
  source String @db.NVarChar(50)

  /// Gönderici RFC 5322 mailbox adresi.
  fromAddress String  @db.NVarChar(320)
  /// İsim parçası — opsiyonel display.
  fromName    String? @db.NVarChar(Max)

  /// Alıcılar — JSON-as-string array. Format: [{"address":"...","name":"..."}].
  /// MSSQL'de JSON native değil; string olarak tutarız (NotificationDispatch
  /// snapshotBody paterniyle hizalı). Parse app-layer.
  toAddresses  String  @db.NVarChar(Max)
  ccAddresses  String? @db.NVarChar(Max)
  bccAddresses String? @db.NVarChar(Max)

  subject  String  @db.NVarChar(Max)
  bodyHtml String  @db.NVarChar(Max)
  /// Düz metin türevi (search/preview/a11y). Outbound'da composer'dan,
  /// inbound'da parsedMail.text'ten doldurulur.
  bodyText String? @db.NVarChar(Max)

  /// RFC 5322 Message-ID — `<...@host>`. Outbound üretilir, inbound parse.
  messageId String? @db.NVarChar(998)
  /// Threading: bu mailin yanıt verdiği Message-ID (RFC 5322 In-Reply-To).
  inReplyTo String? @db.NVarChar(998)
  /// References zinciri (boşluk-ayrılı). Parsing app-layer.
  refs      String? @db.NVarChar(Max)

  /// source='notification_dispatch' için ilgili dispatch FK'ı; paralel
  /// kaydı M4 dispatch ile linkler.
  dispatchId String? @db.NVarChar(450)

  /// 'Customer' | 'Internal'. Plan K2 kararı: composer'dan iç/dış toggle
  /// kaldırıldı; field model'de KALIR (gelecek için yer). Şu an
  /// inbound + outbound = 'Customer'. Notlar tab'ı içsel iletişim için
  /// dokunulmaz kalır.
  visibility String @default("Customer") @db.NVarChar(50)

  /// Agent gönderiminde (M6.2) Varuna user — audit. Inbound + dispatch
  /// için null.
  sentByUserId String? @db.NVarChar(450)

  /// IMAP polling sırasında ham boyut (telemetri/debug).
  rawSize Int?

  /// Envelope ham JSON-as-string (opsiyonel debug).
  headersJson String? @db.NVarChar(Max)

  sentAt     DateTime? // outbound
  receivedAt DateTime? // inbound
  createdAt  DateTime  @default(dbgenerated("sysutcdatetime()"))
  updatedAt  DateTime  @updatedAt

  case        Case                  @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  company     Company               @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sentBy      User?                 @relation("CaseEmailSentBy", fields: [sentByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dispatch    NotificationDispatch? @relation(fields: [dispatchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  attachments CaseEmailAttachment[]

  @@unique([companyId, messageId])
  @@index([caseId, sentAt])
  @@index([caseId, receivedAt])
  @@index([caseId, createdAt])
  @@index([companyId, direction])
  @@index([dispatchId])
}

/// Mail M6.1 — CaseEmail eki. Mail eklerini Case "Dosyalar" tab'ından
/// AYRI tutarız çünkü mail eki orijinal CID/inline metadata'sını korur
/// (HTML body'de cid: referansı bu satırla eşlenir).
///
/// Storage: depolama yolu writeCaseFile/storage.js ile aynı (storageKey
/// burada saklanır); CaseAttachment tablosu DOKUNULMAZ.
model CaseEmailAttachment {
  id         String   @id @default(cuid()) @db.NVarChar(450)
  emailId    String   @db.NVarChar(450)
  /// Storage anahtarı — server/db/storage.js yazımı sonrası dönen relative
  /// path veya object key.
  storageKey String   @db.NVarChar(Max)
  fileName   String   @db.NVarChar(Max)
  mimeType   String   @db.NVarChar(255)
  fileSize   Int
  /// RFC 2392 cid: referansı — HTML body sanitizasyonu sırasında allowlist.
  contentId  String?  @db.NVarChar(Max)
  /// HTML body içinde inline kullanılıyor mu? (cid:foo@bar görsel)
  isInline   Boolean  @default(false)
  createdAt  DateTime @default(dbgenerated("sysutcdatetime()"))

  email CaseEmail @relation(fields: [emailId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([emailId])
}

// ═══════════════════════════════════════════════════════════════════
// WR-ACTION-CENTER Phase 1 — Approval Visibility MVP
// ═══════════════════════════════════════════════════════════════════
//
// Single table covering Phase 1's three approval-related kinds:
//   - approval_pending           (resolved approver receives)
//   - approval_decided           (original submitter FYI)
//   - case_returned_to_assignee  (rejected → assignee revise)
//
// Polymorphic via objectType/objectId — no FK to CaseResolutionApproval
// or Case so cascades stay simple and Phase 2+ kinds can use the same
// table without touching schema. See
// docs/planning_cards/WR-ACTION-CENTER-PHASE1-APPROVAL-VISIBILITY.md §4.

model ActionItem {
  id             String  @id @default(cuid()) @db.NVarChar(450)
  companyId      String  @db.NVarChar(450) // tenant scope
  userId         String  @db.NVarChar(450) // target user
  personId       String? @db.NVarChar(450) // optional Person snapshot (TeamLead routing)
  kind           String  @db.NVarChar(50) // enum:ActionItemKind
  state          String  @default("Pending") @db.NVarChar(50) // enum:ActionItemState
  actionRequired Boolean @default(true)

  // Polymorphic reference (no FK so cascade behavior stays simple)
  objectType String? @db.NVarChar(255)
  objectId   String? @db.NVarChar(450)

  // Denormalized snapshots for inbox rendering (avoid JOIN on list)
  caseId     String? @db.NVarChar(450)
  caseNumber String? @db.NVarChar(Max)
  caseTitle  String? @db.NVarChar(Max)

  // Routing + dedup
  generatedBy String? @db.NVarChar(Max) // 'policy:<id>' | 'system' | 'user:<id>'
  groupKey    String? @db.NVarChar(Max)
  dedupKey    String? @db.NVarChar(255)
  priority    Int     @default(50)

  // Explainability — required, never empty
  reasonLabel String @db.NVarChar(Max)

  // Lifecycle timestamps
  createdAt    DateTime  @default(dbgenerated("sysutcdatetime()"))
  updatedAt    DateTime  @updatedAt
  firstSeenAt  DateTime?
  snoozedUntil DateTime?
  doneAt       DateTime?
  doneByUserId String?   @db.NVarChar(450)
  doneOutcome  String?   @db.NVarChar(Max) // 'approved' | 'rejected' | 'acknowledged'
  closeNote    String?   @db.NVarChar(Max)

  // OD-073 — soft archive. Set by `actionItemArchive` cron 30 days
  // after terminal state transition; never hard-deleted. Active inbox
  // queries filter `archivedAt: null`.
  archivedAt DateTime?

  @@unique([dedupKey])
  @@index([userId, state, createdAt(sort: Desc)])
  @@index([userId, state, actionRequired])
  @@index([companyId, kind, state])
  @@index([objectType, objectId])
  @@index([state, snoozedUntil])
  @@index([state, updatedAt]) // archive cron scan
}

/// Phase 4 — Saved Views.
///
/// Rapor Stüdyosu görünümlerinin tenant-scoped depolanması. Bir kullanıcı
/// kolon seçimini, filtreyi ve (pivot modunda) pivot yapılandırmasını adlı
/// bir şablona kaydeder; daha sonra hızlı yeniden yükler.
///
/// Tenant ve sahiplik:
///   - companyId: zorunlu — tüm queryler allowedCompanyIds ile filtrelenir
///   - ownerId  : kaydeden kullanıcı; PATCH/DELETE sadece sahip için
///   - isShared : false (default) = private (sadece sahip görür)
///                true            = tenant-wide (Supervisor+ rolü gören
///                                   herkes okur, ama düzenleyemez)
///
/// Serileştirme (TEXT/JSON sütunlar):
///   - columns     : seçili kolon ID dizisi, kullanıcı sırasında
///                   (örn. ["caseNumber","status","accountName"])
///   - filters     : ReportFilters JSON (dateFrom, statuses, vb.)
///   - pivotConfig : { rowColumnId, colColumnId, measure: {fn,columnId} }
///                   yalnız mode="pivot" iken anlamlı; mode="list"	a null
///
/// Unique kısıt: (companyId, ownerId, name) — aynı kullanıcı aynı tenant	a
/// aynı isimde 2 view kaydedemez (UI hata gösterir).
model ReportView {
  id          String   @id @default(cuid()) @db.NVarChar(450)
  companyId   String   @db.NVarChar(450)
  ownerId     String   @db.NVarChar(450)
  name        String   @db.NVarChar(200)
  description String?  @db.NVarChar(Max)
  /// "list" | "pivot"
  mode        String   @db.NVarChar(50)
  /// JSON string[] — seçili kolon ID dizisi, sırada
  columns     String   @db.NVarChar(Max)
  /// JSON ReportFilters
  filters     String   @db.NVarChar(Max)
  /// JSON { rowColumnId, colColumnId, measure } — pivot mode için
  pivotConfig String?  @db.NVarChar(Max)
  isShared    Boolean  @default(false)
  createdAt   DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt   DateTime @updatedAt

  owner   User    @relation(fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([companyId, ownerId, name])
  @@index([companyId, ownerId])
  @@index([companyId, isShared])
}

/// Authorization Management — tenant-scoped policy rows.
///
/// MVP persistence foundation only: no runtime enforcement is wired by this
/// migration. `server/lib/authorizationRegistry.js` defines the static
/// vocabulary; `server/lib/authorizationPolicy.js` consumes policy-shaped
/// override rows. This table persists those overrides for later Admin UI and
/// runtime phases.
///
/// target:
///   - "menu"           → menuKey/viewKey + effect
///   - "resource"       → resourceKey + action + effect
///   - "field"          → scope + resourceKey + fieldKey + action + effect
///   - "securityFilter" → resourceKey + filterJson
///
/// principalType:
///   - "systemRole" | "companyRole" | "team" | "user"
///
/// JSON is stored as NVARCHAR(MAX) for MSSQL provider compatibility.
model AuthorizationPolicy {
  id            String @id @default(cuid()) @db.NVarChar(450)
  companyId     String @db.NVarChar(450)
  target        String @db.NVarChar(50)
  principalType String @db.NVarChar(50)
  principalKey  String @db.NVarChar(450)
  effect        String @db.NVarChar(20)

  menuKey     String? @db.NVarChar(150)
  viewKey     String? @db.NVarChar(150)
  resourceKey String? @db.NVarChar(150)
  action      String? @db.NVarChar(50)
  scope       String? @db.NVarChar(100)
  fieldKey    String? @db.NVarChar(150)

  /// Security filter DSL JSON, validated in app-layer by
  /// validateSecurityFilterExpression().
  filterJson String? @db.NVarChar(Max) // json

  priority Int     @default(100)
  isActive Boolean @default(true)
  notes    String? @db.NVarChar(Max)

  createdByUserId String?  @db.NVarChar(450)
  updatedByUserId String?  @db.NVarChar(450)
  createdAt       DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt       DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  createdBy User?   @relation("AuthorizationPolicyCreatedBy", fields: [createdByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedBy User?   @relation("AuthorizationPolicyUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([companyId, target, isActive])
  @@index([companyId, principalType, principalKey])
  @@index([companyId, resourceKey, action])
  @@index([companyId, scope, fieldKey])
  @@index([companyId, menuKey])
}
