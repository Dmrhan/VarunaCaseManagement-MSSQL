// Varuna Case Management — Veri Modeli (MSSQL / on-prem)
//
// Bu schema Postgres'ten SQL Server'a dönüştürülmüştür (Faz 1,
// docs/MSSQL_ONPREM_PLAN_V2.md). Prisma'nın sqlserver connector'ı enum ve
// Json tiplerini desteklemediği için:
// - Eski Prisma enum alanları String'dir; geçerli ASCII değer setleri
//   `// enum:<AdI>` yorumuyla işaretlidir, tek doğruluk kaynağı
//   server/db/enumMap.js + prisma/enum-values.json'dur. DB tarafında
//   kritik alanlar CHECK constraint ile korunur (baseline migration).
// - Eski Json alanları String @db.NVarChar(Max)'tır; `// json` yorumuyla
//   işaretlidir, okuma/yazma uygulama katmanında JSON.parse/stringify ister.
// - Nullable kolon içeren unique'ler DB'de filtered index'tir
//   (WHERE ... IS NOT NULL) — Postgres'in çoklu-NULL davranışı korunur.
//   Bu index'ler baseline migration SQL'inde elle tanımlıdır; `migrate dev`
//   bunları drift sanabilir, yeni migration'larda --create-only ile gözden geçir.
// - Tüm FK'ler onDelete/onUpdate NoAction'dır (MSSQL multiple cascade path
//   kısıtı); silme zincirleri uygulama/transaction katmanında yönetilir.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enum'lar String'e dönüştü — değer setleri: prisma/enum-values.json
// ============================================================

/// Müşteri tipi — WR-A1 / PM-01. Bireysel/Kurumsal/Kamu/Vakıf-STK.
/// TCKN bu enuma rağmen Account'a EKLENMEZ (A2'de privacy design sonrası).

/// Proje statüsü — WR-A4 / PM-04 (AccountProject lifecycle).

/// Adres tipi — WR-A3 / PM-02 (country-agnostic; type-bağlı default uniqueness app-layer).

/// Destek seviyesi — WR-A5 / PM-03 (Phase 1 foundation; SLA/routing entegrasyonu Phase 2).
/// L1/L2 mevcut kullanım; L3/Expert future-proof.

// Spec §13 + Custom Fields/CompanySettings yetkisi için 6. rol.
// SystemAdmin: platform-seviyesi yapılandırma (FieldDefinitions,
// CompanySettings, admin tanım ekranları). Admin: tek-tenant operasyon.

// Per-company role — UserCompany join table'da kullanılır. UserRole'dan
// ayrı tutuldu: User.role sistem-seviyesi default rol (legacy + login akışı),
// UserCompany.role o şirket içindeki yetkiyi belirler. SystemAdmin sistem
// rolü olarak kalır; UserCompany'de görünmesi tüm şirketlere erişim demek
// değil — verifyJwt'de User.role==='SystemAdmin' ise allowedCompanyIds
// tüm şirketlerle dolduruluyor.

// Vakanın neden ertelendiği — Inbox Later sekmesinde sebep ipucu için.

// PatternAlert durumu — Faz 1.5 Madde 5 (Bekçi rolü §5.5 örüntü tespiti).

// CaseLink türü — FAZ 2 Collab. Vakalar arası bağlantı tipi.
//   - Related:   genel ilişkili (yumuşak referans, symmetric değil)
//   - Duplicate: aynı sorun (BFF symmetric davranış — A↔B her iki yön yazılır)
//   - Parent:    bu vaka, hedef vakanın parçası (A → B = A is child of B)

// KnowledgeSource türü — Faz 1.5 Madde 6 (Bilgi Kaynakları Kayıt Defteri).
// AI'ın hangi veriden beslendiğini admin'e şeffaf gösteren kategoriler.

// ============================================================
// Lookup / referans tabloları
// ============================================================

// Spec §13 — Auth + RBAC.
// Faz 3 (on-prem): Supabase Auth kaldırıldı — local e-posta/şifre + JWT.
// id artık cuid (eski Supabase UUID bağı yok). passwordHash bcrypt.
// Person ile ayrı: Person operasyonel kayıt (vaka atama hedefi),
// User auth kimliği. personId opsiyonel FK ile bağlanabilir.
model User {
  id                 String    @id @default(cuid()) @db.NVarChar(450)
  email              String    @unique @db.NVarChar(255)
  fullName           String    @db.NVarChar(Max)
  role               String    @default("Agent") @db.NVarChar(50) // enum:UserRole
  isActive           Boolean   @default(true)
  personId           String?   @unique @db.NVarChar(450)
  /// bcrypt hash; NULL = henüz şifre atanmamış (login reddedilir)
  passwordHash       String?   @db.NVarChar(255)
  /// Admin'in atadığı geçici şifreyle ilk girişte zorunlu değişim bayrağı
  mustChangePassword Boolean   @default(false)
  passwordUpdatedAt  DateTime?
  /// M6.3b Faz 2 — Per-agent imza HTML. NULL → agent imzası yok,
  /// composer fallback chain (agent > tenant > none) tenant default'una
  /// düşer. Save öncesi sanitize-html allowlist (M6.1 deseni).
  /// Sıfır PII; sadece agent görsel kimliği. Self-service: PATCH /api/me/signature.
  signatureHtml      String?   @db.NVarChar(Max)
  createdAt          DateTime  @default(dbgenerated("sysutcdatetime()"))
  updatedAt          DateTime  @updatedAt

  companies                    UserCompany[]
  reminders                    CaseReminder[]
  /// Phase 4 — kullanıcının kaydettiği rapor görünümleri (private/shared).
  reportViews                  ReportView[]
  /// PR-3 — admin audit attribution (6 model × 2 = 12 reverse relation).
  teamsCreated                 Team[]                @relation("TeamCreatedBy")
  teamsUpdated                 Team[]                @relation("TeamUpdatedBy")
  categoriesCreated            CategoryDef[]         @relation("CategoryDefCreatedBy")
  categoriesUpdated            CategoryDef[]         @relation("CategoryDefUpdatedBy")
  slaPoliciesCreated           SLAPolicy[]           @relation("SLAPolicyCreatedBy")
  slaPoliciesUpdated           SLAPolicy[]           @relation("SLAPolicyUpdatedBy")
  fieldDefinitionsCreated      FieldDefinition[]     @relation("FieldDefinitionCreatedBy")
  fieldDefinitionsUpdated      FieldDefinition[]     @relation("FieldDefinitionUpdatedBy")
  taxonomyDefsCreated          TaxonomyDef[]         @relation("TaxonomyDefCreatedBy")
  taxonomyDefsUpdated          TaxonomyDef[]         @relation("TaxonomyDefUpdatedBy")
  checklistTemplatesCreated    ChecklistTemplate[]   @relation("ChecklistTemplateCreatedBy")
  checklistTemplatesUpdated    ChecklistTemplate[]   @relation("ChecklistTemplateUpdatedBy")
  /// PR-5 — Case actor FK back-relations
  caseActivities               CaseActivity[]        @relation("CaseActivityActor")
  caseAttachmentsAsUploader    CaseAttachment[]      @relation("CaseAttachmentUploadedBy")
  authorizationPoliciesCreated AuthorizationPolicy[] @relation("AuthorizationPolicyCreatedBy")
  authorizationPoliciesUpdated AuthorizationPolicy[] @relation("AuthorizationPolicyUpdatedBy")
  /// PR-SD — Soft archive actor FK back-relation
  casesArchived                Case[]                @relation("CaseArchivedBy")
  /// Vaka Sahibi — vakayı açan kullanıcı (creator) FK back-relation
  casesCreated                 Case[]                @relation("CaseCreatedBy")
  /// Mail M6.2 — Agent composer'dan gönderilen mail audit'i (sentByUserId).
  caseEmailsSent               CaseEmail[]           @relation("CaseEmailSentBy")
}

// User ↔ Company N:M köprü. Bir kullanıcı birden çok şirkete erişebilir
// (holding modeli — supervisor/admin'in PARAM + UNIVERA + FINROTA görmesi).
// Liste sorguları req.user.allowedCompanyIds üzerinden filtrelenir;
// SystemAdmin tüm şirketlere otomatik erişir (UserCompany kaydı gerekmez).
model UserCompany {
  id        String   @id @default(cuid()) @db.NVarChar(450)
  userId    String   @db.NVarChar(450)
  companyId String   @db.NVarChar(450)
  role      String   @default("Agent") @db.NVarChar(50) // enum:CompanyRole
  isActive  Boolean  @default(true)
  createdAt DateTime @default(dbgenerated("sysutcdatetime()"))

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  company Company @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

model Company {
  id        String   @id @default(cuid()) @db.NVarChar(450)
  name      String   @unique @db.NVarChar(200)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt DateTime @updatedAt

  accounts                   Account[]
  accountCompanies           AccountCompany[]
  /// WR-A3 — Account adresleri tenant scope için Company'ye bağlı.
  addresses                  Address[]
  teams                      Team[]
  cases                      Case[]
  slaPolicies                SLAPolicy[]
  categories                 CategoryDef[]
  checklists                 ChecklistTemplate[]
  fieldDefinitions           FieldDefinition[]
  settings                   CompanySettings?
  userCompanies              UserCompany[]
  /// WR-A6 / PM-05 — tenant-scoped product catalog.
  productGroups              ProductGroup[]
  products                   Product[]
  /// WR-A7 / PM-05 — tenant-scoped package (contract bundle) catalog.
  packages                   Package[]
  /// WR-KB1 — Dış Bilgi Bankası entegrasyon tanımları (yalnız config; API
  /// çağrısı sonraki fazda). Her şirket için tek satır.
  externalKbSetting          ExternalKbSetting?
  /// DevOps Faz 2.1 — Per-tenant TFS/Azure DevOps integration.
  externalDevOpsSetting      ExternalDevOpsSetting?
  /// Mail M5 — Per-tenant SMTP/IMAP entegrasyon ayarları.
  externalMailSetting        ExternalMailSetting?
  /// Mail M5-extension — Per-company çoklu gönderen adresi alias'ları.
  externalMailFromAliases    ExternalMailSettingFromAlias[]
  /// Mail Multi-Inbox (Faz A) — Per-company çoklu gelen mailbox + takım routing.
  externalMailInboxes        ExternalMailInbox[]
  /// Mail M2.3 — Öğrenilen gönderen→müşteri eşlemeleri.
  learnedSenderAccounts      LearnedSenderAccount[]
  /// Mail M6.1 — Tenant-scoped vaka mailleri.
  caseEmails                 CaseEmail[]
  /// WR-A8 — Data Integration Studio: import job geçmişi.
  importJobs                 ImportJob[]
  /// WR-D4 Phase 1 — tenant-scoped resolution approval policies.
  resolutionApprovalPolicies ResolutionApprovalPolicy[]
  /// WR-D4 Phase 2 — tenant-scoped notification rules + templates + dispatch log.
  notificationRules          NotificationRule[]
  notificationTemplates      NotificationTemplate[]
  notificationDispatches     NotificationDispatch[]
  /// Mail M6.3b Faz 3 — Per-tenant agent composer email template'leri.
  caseEmailTemplates         CaseEmailTemplate[]
  /// WR-Smart-Ticket Phase 1a — tenant-scoped generic taxonomy
  /// (Platform / İş Süreci / İşlem Tipi / Etkilenen Nesne / Etki / Kök
  /// Neden Grubu / Detay / Çözüm Tipi / Kalıcı Önlem). Global entries
  /// (companyId=null) yer almıyor bu liste — yalnız per-tenant.
  taxonomies                 TaxonomyDef[]
  /// WR-Smart-Ticket Phase 2a — tenant-scoped Case çözüm adımları.
  solutionSteps              CaseSolutionStep[]
  /// Phase 4 — tenant-scoped kayıtlı rapor görünümleri.
  reportViews                ReportView[]
  /// Authorization Management — tenant-scoped policy rows for menu,
  /// resource CRUD, field policy, and security filters. Enforcement is
  /// not wired by the initial migration; admin UI/runtime phases consume
  /// this table later.
  authorizationPolicies      AuthorizationPolicy[]
  thirdParties               ThirdParty[]
}

// Şirket başına tanımlanmış custom alanlar — vakaya dinamik olarak eklenir.
// Vaka kaydı sırasında bu tanımlara göre form alanları çıkar; değerler
// Case.customFields JSON'una `{ fieldKey: value }` olarak yazılır.
model FieldDefinition {
  id              String   @id @default(cuid()) @db.NVarChar(450)
  companyId       String   @db.NVarChar(450)
  label           String   @db.NVarChar(Max)
  fieldKey        String   @db.NVarChar(100) // benzersiz tanımlayıcı (örn. "customer_segment")
  fieldType       String   @db.NVarChar(50) // enum:FieldType
  caseType        String?  @db.NVarChar(50) // null = tüm vaka tipleri // enum:CaseType
  isRequired      Boolean  @default(false)
  displayOrder    Int      @default(0)
  /// Select için { value, label }[] dizisi; diğer tipler için null
  options         String?  @db.NVarChar(Max) // json
  isActive        Boolean  @default(true)
  /// PR-3 — admin audit attribution (nullable; eski satırlar NULL)
  createdByUserId String?  @db.NVarChar(450)
  updatedByUserId String?  @db.NVarChar(450)
  createdAt       DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt       DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy User?   @relation("FieldDefinitionCreatedBy", fields: [createdByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedBy User?   @relation("FieldDefinitionUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([companyId, fieldKey])
  @@index([companyId, caseType, isActive])
}

// Şirket başına UI/marka yapılandırması — multi-tenant beyaz etiket için.
model CompanySettings {
  companyId                   String   @id @db.NVarChar(450)
  logoUrl                     String?  @db.NVarChar(Max)
  primaryColor                String?  @db.NVarChar(Max) // hex (#7C3AED gibi)
  appName                     String?  @db.NVarChar(Max)
  supportEmail                String?  @db.NVarChar(Max)
  /// Phase D: true ise vaka açarken müşteri seçimi zorunlu; false (default)
  /// ise Agent "Müşterisiz devam et" ile vaka açabilir ve Case.customerMatchPending
  /// = true set edilir (Supervisor/Admin için eşleştirme kuyruğu).
  requireCustomerOnCaseCreate Boolean  @default(false)
  /// WR-A4 / PM-04 — true ise UI'da AccountProject menüsü + Case create
  /// project combobox açılır. Default false → mevcut davranış değişmez.
  projectsEnabled             Boolean  @default(false)
  /// WR-A4 / PM-04 — true ise (projectsEnabled=true gerektirir) Case create
  /// sırasında accountId varsa accountProjectId zorunlu. Default false →
  /// Phase 1'de hiçbir tenantta aktive değil; UNIVERA için Phase 2 admin
  /// operasyonu ile flip edilir.
  projectsRequired            Boolean  @default(false)
  /// true ise Smart Ticket'ta vaka açmadan önce KB analizi zorunlu. Default false.
  requireKbAnalysis           Boolean  @default(false)
  createdAt                   DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt                   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// WR-KB1 — Dış Bilgi Bankası entegrasyon tanımı (tenant-scoped).
///
/// SADECE configuration. Hiçbir alan API çağrısı tetiklemez; API entegrasyonu
/// sonraki fazda eklenir. Raw API key / secret BURADA TUTULMAZ — yalnız
/// `apiKeySecretName` referans adı (ör. `EXTERNAL_KB_API_KEY`) saklanır;
/// gerçek değer environment secret olarak deploy ortamında yer alır.
///
/// authType:
///   - "none"        — kimlik doğrulama yok
///   - "apiKey"      — API key header (X-Api-Key veya benzeri)
///   - "bearerToken" — Authorization: Bearer
///
/// Per-company admin gate ile yönetilir (assertCompanyAdmin). SystemAdmin
/// tüm şirketleri görür/düzenler.
model ExternalKbSetting {
  id                       String   @id @default(cuid()) @db.NVarChar(450)
  companyId                String   @unique @db.NVarChar(450)
  enabled                  Boolean  @default(false)
  providerName             String?  @db.NVarChar(Max)
  baseUrl                  String?  @db.NVarChar(Max)
  /// WR-KB3 — Yeni endpoint path'leri. ask/search 1. fazda /ask /search default'uyla
  /// shipped olmuştu; gerçek EnRoute KB endpoint'leri /api/v1/... şeklinde. Mevcut
  /// satırlar default'la geliyor; tenant override edebilir.
  askEndpointPath          String   @default("/api/v1/kb/ask") @db.NVarChar(Max)
  searchEndpointPath       String   @default("/api/v1/kb/search") @db.NVarChar(Max)
  healthEndpointPath       String   @default("/api/v1/health") @db.NVarChar(Max)
  statsEndpointPath        String   @default("/api/v1/stats") @db.NVarChar(Max)
  categorizeEndpointPath   String   @default("/api/v1/categorize") @db.NVarChar(Max)
  /// WR-KB-v2 — ticket-analiz API v1 doc §6 (YENİ): 6-alan açılış sınıflandırma
  /// (urun/platform/is_sureci/islem_tipi/etkilenen_nesne/etki). KB kullanmaz,
  /// ~60sn. Smart Ticket "KB ile Analiz Et" bu uca taşındı; eski analyze
  /// path fallback olarak korundu.
  categorizeV2EndpointPath String   @default("/api/v1/categorize-v2") @db.NVarChar(Max)
  /// WR-KB-v2 — ticket-analiz API v1 doc §7 (YENİ): 4-alan kapanış önerisi
  /// (kok_neden_grubu/kok_neden_detayi/cozum_tipi/kalici_onlem). Stage 3
  /// closure'a opsiyonel "AI Önerisi" buton.
  suggestCloseEndpointPath String   @default("/api/v1/suggest-close") @db.NVarChar(Max)
  analyzeEndpointPath      String   @default("/api/v1/analyze") @db.NVarChar(Max)
  /// "none" | "apiKey" | "bearerToken" — string union (Prisma enum gerekli değil; UI tarafı validate eder).
  authType                 String   @default("none") @db.NVarChar(255)
  /// Sadece referans adı (env var key). Raw secret asla saklanmaz.
  apiKeySecretName         String?  @db.NVarChar(Max)
  timeoutMs                Int      @default(30000)
  defaultTopK              Int      @default(8)
  /// "lenient" | "normal" | "strict" — kb/ask + kb/search için varsayılan.
  defaultStrictness        String   @default("lenient") @db.NVarChar(Max)
  defaultRerank            Boolean  @default(true)
  defaultVerify            Boolean  @default(true)
  showCitations            Boolean  @default(true)
  allowAgentUse            Boolean  @default(true)
  allowSupervisorUse       Boolean  @default(true)
  allowCsmUse              Boolean  @default(true)
  notes                    String?  @db.NVarChar(Max)
  createdAt                DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt                DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([companyId, enabled])
}

/// DevOps Faz 2.1 — Per-tenant TFS/Azure DevOps entegrasyon ayarları.
///
/// Tek satır per company (companyId @unique). devopsClient.getConfig()
/// önce bu tabloya bakar; satır yoksa process.env.TFS_* fallback (MVP
/// backward-compat). enabled=false ise entegrasyon KAPALI (env fallback
/// YAPILMAZ — gerçekten kapalı semantiği).
///
/// PAT şifrelemesi: AES-256-GCM (server/lib/secretCipher.js).
/// Plain PAT DB'de ASLA saklanmaz; ciphertext + iv + authTag base64
/// üçlüsü ve patSetAt timestamp tutulur. GET response'unda hiçbir
/// ciphertext alanı DÖNMEZ; sadece patIsSet boolean + patSetAt.
model ExternalDevOpsSetting {
  id              String    @id @default(cuid()) @db.NVarChar(450)
  companyId       String    @unique @db.NVarChar(450)
  enabled         Boolean   @default(false)
  baseUrl         String?   @db.NVarChar(Max)
  apiVersion      String?   @db.NVarChar(50)
  timeoutMs       Int       @default(15000)
  /// Faz 2.1 follow-up — Basic auth kullanıcı adı (örn. "DOMAIN\user").
  /// On-prem TFS user+secret bekliyor; cloud Azure DevOps yalnız PAT
  /// kabul ettiğinden username nullable. Username SECRET DEĞİL, plain
  /// saklanır; PAT/parola hâlâ AES-256-GCM şifreli kalır.
  username        String?   @db.NVarChar(256)
  /// AES-256-GCM ciphertext (base64). null → PAT henüz set edilmedi.
  patCiphertext   String?   @db.NVarChar(Max)
  /// 12-byte IV (base64). ciphertext ile aynı set/clear semantiği.
  patIv           String?   @db.NVarChar(Max)
  /// 16-byte GCM authTag (base64).
  patAuthTag      String?   @db.NVarChar(Max)
  /// PAT'in en son set edildiği zaman (rotation tracking).
  patSetAt        DateTime?
  createdByUserId String?   @db.NVarChar(450)
  updatedByUserId String?   @db.NVarChar(450)
  createdAt       DateTime  @default(dbgenerated("sysutcdatetime()"))
  updatedAt       DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([companyId, enabled])
}

/// Mail M5 — Per-tenant SMTP/IMAP entegrasyon ayarları.
///
/// Tek satır per company (companyId @unique). mailProvider.sendMail
/// per-tenant config kullanırken (opts.companyId verildi) önce bu tabloya
/// bakar; satır yoksa process.env (SMTP_*, MAIL_TRANSPORT) fallback
/// (M1 backward-compat). enabled=false ise entegrasyon KAPALI semantiği
/// (env'e DÜŞMEZ, ExternalDevOpsSetting kuralının aynısı).
///
/// Sır şifrelemesi: AES-256-GCM (server/lib/secretCipher.js;
/// DEVOPS_PAT_ENC_KEY env reuse — DevOps PAT için doğdu, M5'te mail
/// secret'ları da bu key ile şifreli). Plain secret DB'de ASLA saklanmaz;
/// ciphertext + iv + authTag base64 üçlüsü + secretSetAt timestamp.
///
/// GET response'unda hiçbir ciphertext alanı dönmez; sadece secretIsSet
/// boolean + secretSetAt.
model ExternalMailSetting {
  id               String    @id @default(cuid()) @db.NVarChar(450)
  companyId        String    @unique @db.NVarChar(450)
  enabled          Boolean   @default(false)
  /// Giden mail için "From" adresi (örn. "Varuna <no-reply@univera.com.tr>").
  ///
  /// M5-extension (K1) — Bu alan LEGACY / VARSAYILAN konumuna düştü.
  /// Çoklu gönderen adresi artık ExternalMailSettingFromAlias 1:N ile
  /// modellenir. Backfill migration 17: bu değer dolu olan tenant için
  /// bir FromAlias(isDefault=true) satırı oluşturulur. Composer (M6.2)
  /// dropdown'u sadece FromAlias listesinden beslenir; gönderim
  /// validation'ı seçilen from'un AKTİF alias'lardan biri olmasını
  /// zorlar.
  /// Geri uyumluluk: backend tarafından okuyan eski kod (notification
  /// dispatch paralel CaseEmail vs.) çalışmaya devam eder; ilk default
  /// alias bu değeri yansıtır.
  fromAddress      String?   @db.NVarChar(Max)
  /// IMAP polling hedefi (M3'te kullanılır; M5'te admin set eder).
  ///
  /// Multi-Inbox A1 (2026-06-30) — Bu alan LEGACY / VARSAYILAN konumuna
  /// düştü. Çoklu gelen mailbox artık ExternalMailInbox 1:N ile modellenir.
  /// A1 backfill migration: bu değer dolu olan tenant için bir adet
  /// ExternalMailInbox satırı oluşturulur (displayName='Varsayılan',
  /// imapHost/port + username + secret parent'tan kopyalanır). IMAP
  /// polling A2'de yeni tablodan okur; bu alan yalnız legacy fallback
  /// olarak ve admin UI'da "ana inbox" görsel referansı için durur.
  ///
  /// Geri uyumluluk: yeni kayıtlar bu alanı doldurmayabilir; mevcut
  /// satırlar düşürülmedi (FromAlias #17 deseninin aynısı).
  inboundAddress   String?   @db.NVarChar(Max)
  /// SMTP gönderim (M1 + M4).
  smtpHost         String?   @db.NVarChar(Max)
  smtpPort         Int?
  smtpSecure       Boolean   @default(false)
  /// IMAP polling (M3).
  imapHost         String?   @db.NVarChar(Max)
  imapPort         Int?
  /// Auth modu — 'password' (M1+M5 — App Password / SMTP pwd) veya
  /// 'oauth2' (M3+ — Google Workspace OAuth2). M5'te yalnız 'password'.
  authMode         String    @default("password") @db.NVarChar(50)
  /// AES-256-GCM ciphertext (base64). null → secret henüz set edilmedi.
  /// 'password' modunda SMTP password; 'oauth2' modunda refresh_token (M3).
  secretCiphertext String?   @db.NVarChar(Max)
  /// 12-byte IV (base64). ciphertext ile aynı set/clear semantiği.
  secretIv         String?   @db.NVarChar(Max)
  /// 16-byte GCM authTag (base64).
  secretAuthTag    String?   @db.NVarChar(Max)
  /// secret'in en son set edildiği zaman (rotation tracking).
  secretSetAt      DateTime?
  /// SMTP/IMAP kullanıcı adı (genelde inboundAddress ile aynı). Secret
  /// DEĞİL, plain saklanır.
  username         String?   @db.NVarChar(256)
  /// M6.2a — Per-tenant default mail imzası (sanitize-html ile temizlenmiş
  /// HTML). M6.2b composer gövdeye otomatik append eder; agent silebilir.
  /// Per-agent override M6.3'te (User.signatureHtml).
  signatureHtml    String?   @db.NVarChar(Max)
  createdByUserId  String?   @db.NVarChar(450)
  updatedByUserId  String?   @db.NVarChar(450)
  createdAt        DateTime  @default(dbgenerated("sysutcdatetime()"))
  updatedAt        DateTime  @updatedAt

  company     Company                        @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  /// M5-extension — Per-company çoklu gönderen adresi alias'ları.
  fromAliases ExternalMailSettingFromAlias[]

  @@index([companyId, enabled])
}

/// Mail M5-extension (K1) — Per-company çoklu "From" adresi alias'ı.
///
/// Plan referansı: docs/M6-email-in-case-plan.md Bölüm 4.4.
///
/// Composer (M6.2) dropdown'u bu listeden beslenir. Validation: agent'ın
/// seçtiği From değeri o şirketin AKTİF alias'larından biri olmalı; aksi
/// halde gönderim reddedilir (spoof önleme).
///
/// Backfill (migration 17): mevcut ExternalMailSetting.fromAddress dolu
/// her tenant için bir alias(isDefault=true, isActive=true) yazılır.
///
/// NOT: Bu model SADECE çoklu GÖNDEREN ADRESİ. Her alias'ın kendi
/// inbound/SMTP'si YOK (tek mailbox, çoklu adres). Sırlar
/// ExternalMailSetting'te kalır; FromAlias yalnız adres/display/default.
model ExternalMailSettingFromAlias {
  id                    String   @id @default(cuid()) @db.NVarChar(450)
  companyId             String   @db.NVarChar(450)
  /// FK convenience — birebir ExternalMailSetting.id'yle eşleşir; ama
  /// composer lookup companyId üzerinden filtreler, bu yüzden companyId
  /// indeksi tutarız. setting silindiyse cascade.
  externalMailSettingId String?  @db.NVarChar(450)
  /// RFC 5322 mailbox. Normalize: trim; case-sensitive saklanır ama
  /// @@unique key normalize değil (basit); uygulama katmanında trim+
  /// lowercase karşılaştırma. Format: "Display Name <addr@host>" veya
  /// sade "addr@host". MSSQL key length sınırı için NVarChar(450).
  address               String   @db.NVarChar(450)
  /// Composer dropdown'da gösterilen etiket. Boş ise address kullanılır.
  displayName           String?  @db.NVarChar(Max)
  /// Default alias — composer açılışında ön-seçili; tenant başına 1 satır
  /// true olmalı (uygulama katmanı zorlar). null'sa ilk aktif alias
  /// default kabul.
  isDefault             Boolean  @default(false)
  isActive              Boolean  @default(true)
  /// UI sıralaması.
  sortOrder             Int      @default(100)
  createdByUserId       String?  @db.NVarChar(450)
  updatedByUserId       String?  @db.NVarChar(450)
  createdAt             DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt             DateTime @updatedAt

  company Company              @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  /// MSSQL multi-cascade engelleme — Company zaten cascade; setting
  /// silinirse alias'lar companyId üzerinden hala scope'da kalır.
  setting ExternalMailSetting? @relation(fields: [externalMailSettingId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /// Per-tenant adres unique. Aynı tenant'ta aynı adresi iki kez ekleme.
  @@unique([companyId, address])
  @@index([companyId, isActive])
  @@index([companyId, isDefault])
  @@index([externalMailSettingId])
}

/// Mail Multi-Inbox (Faz A) — Per-company çoklu gelen mailbox.
///
/// İhtiyaç: Bir tenant artık birden fazla mail adresinden gelen vakaları
/// AYRI takımlara yönlendirebilir. Örn. UNIVERA için:
///   - yazilimdestek@univera.com.tr → Yazılım Takımı havuzu
///   - satis@univera.com.tr        → Satış Takımı havuzu
///   - finans@univera.com.tr       → Finans Takımı havuzu
///
/// Mimari karar (2026-06-30 onaylı):
///   1) Her inbox AYRI IMAP hesabı (kendi username/password). Tek hesap +
///      N alias varyantı YOK; ENVELOPE/folder routing'e gerek kalmadı.
///   2) Routing SADECE assignedTeamId — category/priority/caseType
///      override YOK (intake DEFAULT'ları korunur).
///   3) Atama MODELİ HAVUZ — assignedTeamId set, assignedPersonId YOK
///      (mevcut "kimse atanmaz" pattern'in takıma hedefli hali).
///   4) Backfill — mevcut ExternalMailSetting.inboundAddress dolu her
///      tenant için 'default' inbox kaydı oluşturulur (eski tek-inbox
///      davranışı kırılmaz). FromAlias migration deseninin aynısı.
///
/// FromAlias (giden) ile semantik AYRI ama desen aynı:
///   - FromAlias = SMTP send dropdown (composer "From" seçimi)
///   - ExternalMailInbox = IMAP polling kaynağı + intake routing
///
/// Secret cipher: M5 paterni reuse (AES-256-GCM, DEVOPS_PAT_ENC_KEY).
model ExternalMailInbox {
  id          String  @id @default(cuid()) @db.NVarChar(450)
  companyId   String  @db.NVarChar(450)
  /// Inbox adresi (örn. yazilimdestek@univera.com.tr). Per-tenant unique.
  /// Normalize: app katmanı trim + lowercase karşılaştırma yapar.
  address     String  @db.NVarChar(450)
  /// Admin UI label (örn. "Yazılım Destek"). Boş ise address gösterilir.
  displayName String? @db.NVarChar(Max)

  /// IMAP credentials — her inbox kendi hesabı (mimari karar #1).
  imapHost         String?   @db.NVarChar(Max)
  imapPort         Int?
  imapSecure       Boolean   @default(true)
  /// IMAP login kullanıcı adı (genelde address ile aynı). Secret DEĞİL,
  /// plain saklanır.
  username         String?   @db.NVarChar(256)
  /// AES-256-GCM ciphertext (base64). null → secret henüz set edilmedi.
  /// 'password' modunda IMAP password (App Password).
  secretCiphertext String?   @db.NVarChar(Max)
  secretIv         String?   @db.NVarChar(Max)
  secretAuthTag    String?   @db.NVarChar(Max)
  /// Secret'in en son set edildiği zaman (rotation tracking).
  secretSetAt      DateTime?

  /// Routing hedefi — bu inbox'a düşen mailler bu takıma atanır (havuz).
  /// null → havuz tanımsız (vakalar global havuza düşer, eski davranış).
  assignedTeamId String? @db.NVarChar(450)

  /// Polling açık mı (per-inbox toggle; ExternalMailSetting.enabled global toggle ile birlikte değerlendirilir).
  enabled   Boolean @default(false)
  /// Soft delete — false ise CRUD listede gizli + polling atlar.
  isActive  Boolean @default(true)
  /// UI sıralaması.
  sortOrder Int     @default(100)

  createdByUserId String?  @db.NVarChar(450)
  updatedByUserId String?  @db.NVarChar(450)
  createdAt       DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  /// Team relation NO ACTION — Team silinirse inbox routing'i NULL'a
  /// düşürülmez (MSSQL multi-cascade engelleme); manuel cleanup app
  /// katmanında. Team delete akışı zaten Team.deletedAt soft pattern.
  team    Team?   @relation(fields: [assignedTeamId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /// Per-tenant adres unique.
  @@unique([companyId, address])
  @@index([companyId, enabled])
  @@index([companyId, isActive])
  @@index([assignedTeamId])
}

/// Mail M6.3b Faz 3 — Agent composer "Mail Şablonu" dropdown'unu
/// besleyen yeniden kullanılabilir email gövde şablonları.
///
/// Plan referansı: M6.3b plan §Faz 3 — n4b parite + endüstri araştırması
/// (Zendesk macros, Freshdesk canned responses, Gmail templates).
///
/// NotificationTemplate (model 2288) ile AYRIDIR:
///   - NotificationTemplate = sistem rule-driven dispatch (key='approval_pending_to_lead')
///   - CaseEmailTemplate = agent self-service taslaklar (manuel insert)
///   Semantik ayrı; admin UI'da iki ayrı sekme.
///
/// Composer akışı:
///   1. Agent composer'da "Mail Şablonu" dropdown'undan seçer
///   2. Subject opsiyonel; varsa "Mevcut subject'i değiştir?" modal onay
///   3. bodyHtml TipTap insertContent ile cursor pozisyonuna eklenir
///   4. Placeholder render: backend POST /api/cases/:id/email-templates/:id/preview
///      Mustache benzeri {{varName}} interpolation, requiredVariables
///      whitelist (6 sistem placeholder v1: case.number/case.title/
///      account.name/requester.name/requester.email/agent.fullName).
///
/// Per-tenant — companyId scope. Faz 3 v1: admin only create.
model CaseEmailTemplate {
  id              String   @id @default(cuid()) @db.NVarChar(450)
  companyId       String   @db.NVarChar(450)
  /// Template adı (display + dropdown). Per-tenant unique.
  name            String   @db.NVarChar(255)
  /// Opsiyonel kategori (admin organize için). Free-form string;
  /// klasör hiyerarşi v2.
  category        String?  @db.NVarChar(100)
  /// Subject template — opsiyonel. Verilirse composer subject'i replace
  /// confirm modal'la değiştirir.
  subject         String?  @db.NVarChar(Max)
  /// Body template — zorunlu. Sanitize-html allowlist (M6.1) save öncesi.
  bodyHtml        String   @db.NVarChar(Max)
  /// Declared placeholder whitelist — Backend preview engine'i bu listede
  /// olmayan {{vars}} için warning verir. JSON string; ileride yapılandırılabilir.
  variables       String   @db.NVarChar(Max)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt       DateTime @updatedAt
  createdByUserId String?  @db.NVarChar(450)
  updatedByUserId String?  @db.NVarChar(450)

  company Company @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /// Per-tenant ad unique — composer dropdown'unda aynı adlı template iki kez olmasın.
  @@unique([companyId, name])
  @@index([companyId, isActive])
}

/// Mail M2.3 — Öğrenilen gönderen→müşteri eşlemesi.
///
/// Manuel link sırasında insan onaylı bir eşleme oluşturulur:
///   "Bu sender email, bu account'a aittir."
/// Sonraki inbound mail aynı gönderenden geldiğinde:
///   - Kişisel adres (isRoleAddress=false) → 'learned' reason ile OTOMATİK BAĞLA
///   - Rol adres (info@/support@/sales@/...) → 'learned' reason ile SADECE ÖNERİ
///
/// Tek MANUEL linkAccount çağrıları öğrenir (route layer'da source='manual');
/// intake AUTO-link çağrıları öğrenmez (redundant).
///
/// Self-correction: yeni manuel link OVERWRITE eder (en güncel insan
/// kararı kazanır). companyId + senderEmail @unique → bir şirkette bir
/// gönderen = bir eşleme.
///
/// Tenant izolasyon: companyId scope; aynı senderEmail farklı şirkette
/// farklı account'a bağlanabilir.
///
/// Spec: docs/MAIL_INTEGRATION.md M2.3 (varsa) / PR feature/mail-learned-sender-m2-3
model LearnedSenderAccount {
  id              String   @id @default(cuid()) @db.NVarChar(450)
  companyId       String   @db.NVarChar(450)
  /// Normalize edilmiş (trim + lowercase) gönderen e-posta.
  senderEmail     String   @db.NVarChar(320)
  accountId       String   @db.NVarChar(450)
  /// Rol adresi mi (info@, support@, sales@ vb.)? Auto-link tetiklemesi
  /// için kişisel adresler (isRoleAddress=false) yetkili; rol adresleri
  /// yalnız öneri üretir.
  isRoleAddress   Boolean  @default(false)
  /// Hangi kaynaktan öğrenildi. M2.3'te sabit 'manual_link'; ileride
  /// 'admin_explicit' gibi değerler eklenebilir.
  source          String   @default("manual_link") @db.NVarChar(50)
  /// Manuel linki yapan user (audit).
  createdByUserId String?  @db.NVarChar(450)
  createdAt       DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([companyId, senderEmail])
  @@index([companyId])
  @@index([accountId])
}

// CaseAccount — müşteri kaydı (Varuna CRM gelene kadar lokal)
// Phase A: Account global kimlik. Şirkete özel alanlar (Univera kodu, paket,
// kontrat) AccountCompany tablosunda tutulur. Account.companyId legacy alandır
// ve mevcut Case scope sorguları için geri uyumlu kalır.
model Account {
  id               String   @id @default(cuid()) @db.NVarChar(450)
  name             String   @db.NVarChar(200)
  /// Vergi numarası — global unique. Phase A: plain saklanır, response'ta maskeli döner.
  /// WR-A2: format + checksum validation app-layer'da (server/utils/accountValidation.js).
  vkn              String?  @unique @db.NVarChar(20)
  companyId        String?  @db.NVarChar(450)
  email            String?  @db.NVarChar(255)
  /// Display amaçlı orijinal telefon (kullanıcı girdiği format). WR-A2'de phoneE164 ayrı tutulur.
  phone            String?  @db.NVarChar(Max)
  /// WR-A2 — E.164 normalize (örn. "+905325551234"). Search/index için.
  /// **DB unique constraint YOK** — paylaşılan call center numarası iki Account'ta görünebilir.
  phoneE164        String?  @db.NVarChar(20)
  /// Phase 2 phone metadata — telefon tipi: 'mobile' | 'work' |
  /// 'switchboard' | 'whatsapp' | 'other'. Storage'daki canonical değer
  /// E.164 phoneE164 alanı; phoneType yalnız operasyonel sinyal.
  phoneType        String?  @db.NVarChar(255)
  /// Phase 2 phone metadata — dahili numara (santral arkası). E.164
  /// phoneE164'a APPEND edilmez; ayrı kolonda tutulur. 1-10 char.
  phoneExtension   String?  @db.NVarChar(Max)
  /// Phase 3 — Account başına 3 telefon slot. Slot 1 yukarıdaki phone*
  /// alanları; slot 2/3 ek paralel kolonlardır. Generic PhoneNumber
  /// tablosu eklenmedi — sabit max=3 ürün kuralı.
  phone2           String?  @db.NVarChar(Max)
  phone2E164       String?  @db.NVarChar(20)
  phone2Type       String?  @db.NVarChar(255)
  phone2Extension  String?  @db.NVarChar(Max)
  phone3           String?  @db.NVarChar(Max)
  phone3E164       String?  @db.NVarChar(20)
  phone3Type       String?  @db.NVarChar(255)
  phone3Extension  String?  @db.NVarChar(Max)
  /// Phase 3 — Hangi slot Account için "birincil telefon" (1/2/3).
  /// Null ise UI ilk dolu slotu birincil kabul eder. Backend her create/
  /// update'te boş olmayan ilk slota normalize eder; boş slotu işaret
  /// edemez.
  primaryPhoneSlot Int?
  isActive         Boolean  @default(true)
  /// WR-A1 / PM-01 — Müşteri tipi (B2B/B2C ayırımı). Mevcut hesaplar Corporate default ile gelir.
  customerType     String   @default("Corporate") @db.NVarChar(50) // enum:CustomerType
  /// Faz B-temel (2026-06-30) — Müşteri Türü (rol/ilişki sınıfı), Univera-FMCG iş modeli.
  ///
  /// customerType (LEGAL tip) ile FARKLI alan; UI'da yan yana gösterilir:
  ///   - customerType (Müşteri Tipi)   = yasal/tüzel sınıf (Kurumsal/Bireysel/Kamu/Vakıf)
  ///   - customerRole (Müşteri Türü)   = bizimle çalışma rolü
  ///
  /// 6 değer (n4b parite — ASCII normalize):
  ///   Merkez Müşteri      → Central
  ///   Distribütör/Bayi    → Distributor
  ///   Bölge Müdürlüğü     → RegionalOffice
  ///   Kanal/Çözüm Ortağı  → ChannelPartner
  ///   Yurt Dışı           → International
  ///   Stokbar             → Stockbar
  ///
  /// Nullable — mevcut Account'lar boş kalır; admin sonra doldurur.
  ///
  /// Faz B bülteni: AccountProject.anaFirmaAccountId yalnız customerRole='Central'
  /// olan account'lara işaret eder. Rol değişiminde bağlı proje koruması var
  /// (app-layer WARN; silent cascade-null YASAK).
  customerRole     String?  @db.NVarChar(50) // enum:CustomerRole
  /// Kurumsal müşterinin tam ticari unvanı (opsiyonel). Bireysel için tipik olarak NULL.
  legalName        String?  @db.NVarChar(Max)
  /// Ticaret sicil no veya muadili (opsiyonel). Bireysel için tipik olarak NULL.
  registrationNo   String?  @db.NVarChar(Max)
  /// Vergi Dairesi — kurumsal müşteri ana kartında VKN'den önce gösterilir.
  /// Bireysel müşterilerde tipik olarak NULL. Yalnız descriptive metadata;
  /// matching/import key DEĞİL, search index'i yok.
  taxOffice        String?  @db.NVarChar(Max)
  /// WR-A2 / Decision Sprint #1 — TCKN HMAC-SHA256(plain, TCKN_HASH_PEPPER), 64-char hex.
  /// **Plain TCKN ASLA saklanmaz.** Global unique → duplicate Bireysel müşteri önleme.
  /// Pepper env yoksa write path 400 fail; read path (search) sessizce skip.
  tcknHash         String?  @unique @db.NVarChar(64)
  /// WR-A2 — Display için son 4 hane (örn "1234"). UI'da "*******1234" maskeli gösterilir.
  tcknLast4        String?  @db.NVarChar(Max)
  createdAt        DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt        DateTime @updatedAt

  company               Company?               @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cases                 Case[]
  companies             AccountCompany[]
  contacts              AccountContact[]
  /// WR-A3 / PM-02 — country-agnostic address book. Account silindiğinde cascade.
  addresses             Address[]
  /// Mail M2.3 — Bu account'a öğrenilmiş sender eşlemeleri.
  learnedSenderAccounts LearnedSenderAccount[]
  /// Faz B-temel — Bu Merkez Müşteri'nin (Nestlé vb.) ana firma olarak
  /// işaret edildiği projeler (bayilerin projeleri). customerRole='Central'
  /// olmayanlar için bu liste boş kalır.
  anaFirmaProjects      AccountProject[]       @relation("AccountProjectAnaFirma")

  @@index([companyId])
  @@index([name])
  @@index([customerType])
  @@index([customerRole])
  @@index([phoneE164])
  @@index([phone2E164])
  @@index([phone3E164])
}

// AccountCompany — Account ile Company arasında per-tenant ilişki.
// Aynı müşteri (Account) birden çok şirkete (PARAM/UNIVERA/FINROTA) bağlı
// olabilir; şirkete özel kod, paket, kontrat ve segment burada tutulur.
model AccountCompany {
  id                   String    @id @default(cuid()) @db.NVarChar(450)
  accountId            String    @db.NVarChar(450)
  companyId            String    @db.NVarChar(450)
  /// Univera 5 haneli müşteri kodu — şirket içinde unique.
  externalCustomerCode String?   @db.NVarChar(255)
  /// WR-A7b — Legacy free-text paket adı. packageId set olsa bile snapshot olarak korunur;
  /// packageId clear edilse de packageName silinmez (D-A7BI.1).
  packageName          String?   @db.NVarChar(Max)
  /// WR-A7b — Tenant-scoped Package referansı. Package.companyId === AccountCompany.companyId
  /// invariantı app-layer'da enforce edilir (DI.1).
  packageId            String?   @db.NVarChar(450)
  contractStartAt      DateTime?
  contractEndAt        DateTime?
  segment              String?   @db.NVarChar(Max)
  status               String    @default("active") @db.NVarChar(255) // active | churn | prospect | inactive
  notes                String?   @db.NVarChar(Max)

  // WR-D4/D3 Phase 3 — Customer Response Channel preferences (per
  // tenant-customer link). Used by NotificationDispatch audience
  // resolution to decide where customer-facing messages should land.
  //
  // - preferredResponseChannel: 'email' | 'phone' | 'manual' (free string
  //   so 'portal' or other future channels can be plugged in without a
  //   migration).
  // - responseEmail / responsePhone: explicit override addresses. When
  //   set, they win over AccountContact.email/phone (fallback chain
  //   documented in §10.3 of the planning card).
  // - allowCustomerNotifications: opt-out gate. When false, all customer-
  //   facing dispatches are written as Suppressed/customer_opted_out.
  preferredResponseChannel   String? @db.NVarChar(255)
  responseEmail              String? @db.NVarChar(Max)
  responsePhone              String? @db.NVarChar(Max)
  allowCustomerNotifications Boolean @default(true)

  createdAt DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt DateTime @updatedAt

  account  Account          @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  package  Package?         @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products AccountProduct[]
  /// WR-A4 — AccountCompany-scoped projeler.
  projects AccountProject[]

  @@unique([accountId, companyId])
  @@unique([companyId, externalCustomerCode])
  @@index([companyId])
  @@index([accountId])
  @@index([externalCustomerCode])
  @@index([packageId])
}

/// AccountProject — WR-A4 / PM-04. UNIVERA gibi proje bazlı müşterilerin
/// projelerini AccountCompany altında tutar. Case.accountProjectId üzerinden
/// vakalara bağlanır.
///
/// Tasarım kuralı (Decision Sprint §④, Modeling Guardrail #2):
///   Account → AccountCompany → AccountProject → Case
///   Project ASLA doğrudan Account'a bağlanmaz.
///
/// CompanySettings.projectsEnabled flag'i (default false) tenant başına opt-in;
/// projectsRequired (default false) Case create'te projectId'yi zorunlu yapar.
model AccountProject {
  id                String    @id @default(cuid()) @db.NVarChar(450)
  accountCompanyId  String    @db.NVarChar(450)
  /// Tenant-içi unique kod (AccountCompany scope'unda). Örn "ROTA-2026".
  code              String    @db.NVarChar(255)
  name              String    @db.NVarChar(Max)
  status            String    @default("Active") @db.NVarChar(50) // enum:ProjectStatus
  startDate         DateTime?
  endDate           DateTime?
  description       String?   @db.NVarChar(Max)
  isActive          Boolean   @default(true)
  /// Persistent source-of-truth id from the external ERP/CRM. Optional.
  /// Customer 360 re-imports use (accountCompanyId, sourceExternalId) to
  /// update the same Project row instead of creating a duplicate.
  sourceExternalId  String?   @db.NVarChar(450)
  /// Faz B-temel (2026-06-30) — Ana firma (Merkez Müşteri) referansı.
  ///
  /// Univera-FMCG iş modeli: bir bayinin (AccountCompany üzerinden) projesi,
  /// hangi ana firmaya (Nestlé/Mondelez/JTI...) ait olduğunu BURADA YAPISAL
  /// taşır. Nullable — mevcut projeler boş kalır.
  ///
  /// Sadece Account.customerRole='Central' olan account'lar burada
  /// referans edilebilir (app-layer guard, repo'da enforce).
  ///
  /// Cross-tenant guard: anaFirma.accountCompanies içinde bayi'nin
  /// accountCompany.companyId'sine eşleşen bir kayıt olmalı (aynı tenant).
  ///
  /// FK: Account silindiğinde NO ACTION (MSSQL multi-cascade engelleme —
  /// Account→AccountCompany→AccountProject zaten cascade path; ek cascade
  /// SQL'de "multiple cascade paths" hatası verir).
  anaFirmaAccountId String?   @db.NVarChar(450)
  createdAt         DateTime  @default(dbgenerated("sysutcdatetime()"))
  updatedAt         DateTime  @updatedAt

  accountCompany AccountCompany @relation(fields: [accountCompanyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  anaFirma       Account?       @relation("AccountProjectAnaFirma", fields: [anaFirmaAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cases          Case[]

  @@unique([accountCompanyId, code])
  @@index([accountCompanyId])
  @@index([accountCompanyId, isActive])
  @@index([accountCompanyId, sourceExternalId])
  @@index([anaFirmaAccountId])
}

// AccountProduct — Müşterinin bir şirketteki kullandığı ürün/servis listesi.
// Vaka açma akışında müşteri context'ini zenginleştirir; vaka için zorunlu değil.
model AccountProduct {
  id               String    @id @default(cuid()) @db.NVarChar(450)
  accountCompanyId String    @db.NVarChar(450)
  /// WR-A6/A8 — Tenant-scoped Product Catalog'a opsiyonel FK. Tanım:
  ///  - Set ise: Product.companyId === AccountCompany.companyId invariantı
  ///    app-layer'da enforce edilir (cross-tenant reddedilir, code=product_company_mismatch).
  ///  - Null ise: legacy free-text (productName/productCode) modu korunur.
  ///  Snapshot pattern (A7b): catalog set olsa bile productName/productCode
  ///  alanları snapshot olarak yazılır → Product silinince/rename olunca display kırılmaz.
  productId        String?   @db.NVarChar(450)
  productName      String    @db.NVarChar(Max)
  productCode      String?   @db.NVarChar(255)
  isActive         Boolean   @default(true)
  startedAt        DateTime?
  endedAt          DateTime?
  createdAt        DateTime  @default(dbgenerated("sysutcdatetime()"))
  updatedAt        DateTime  @updatedAt

  accountCompany AccountCompany @relation(fields: [accountCompanyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  /// MSSQL: Company→Product ve Company→AccountCompany→AccountProduct çift path
  /// nedeniyle SetNull olamaz (multiple cascade paths). Product silinirken
  /// productId uygulama katmanında null'lanmalı (admin product delete akışı).
  product        Product?       @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([accountCompanyId, productCode])
  @@index([accountCompanyId])
  @@index([productId])
}

// AccountContact — Account altında kişi kayıtları (karar verici, teknik lider vb.).
// Global tutulur; ileride per-company role linkleri eklenebilir.
model AccountContact {
  id               String   @id @default(cuid()) @db.NVarChar(450)
  accountId        String   @db.NVarChar(450)
  fullName         String   @db.NVarChar(Max)
  title            String?  @db.NVarChar(Max)
  email            String?  @db.NVarChar(Max)
  phone            String?  @db.NVarChar(Max)
  /// WR-A2 — E.164 normalize. Account.phoneE164 ile aynı kural; DB unique yok.
  phoneE164        String?  @db.NVarChar(20)
  /// Phase 2 phone metadata — telefon tipi: 'mobile' | 'work' |
  /// 'switchboard' | 'whatsapp' | 'other'.
  phoneType        String?  @db.NVarChar(255)
  /// Phase 2 phone metadata — dahili numara. phoneE164'a append edilmez.
  phoneExtension   String?  @db.NVarChar(Max)
  /// Account içinde "birincil iletişim" işaretçisi. Bu PR'da telefon
  /// "Birincil Telefon" semantiği de buraya yığılır — başka contact
  /// "isPrimary=true" yapıldığında commit engine bu alanı otomatik
  /// demote eder (server/lib/import/customer360CommitEngine.js).
  isPrimary        Boolean  @default(false)
  isActive         Boolean  @default(true)
  /// Tercih edilen iletişim kanalı — 'email' | 'phone' | 'whatsapp' vs.
  preferredChannel String?  @db.NVarChar(255)
  /// Persistent source-of-truth id from the external ERP/CRM. Optional.
  /// Customer 360 re-imports use (accountId, sourceExternalId) to update
  /// the same Contact row instead of creating a duplicate. App-layer
  /// uniqueness only — no DB unique to keep imports race-tolerant.
  sourceExternalId String?  @db.NVarChar(450)
  createdAt        DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt        DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([accountId])
  @@index([phoneE164])
  @@index([accountId, sourceExternalId])
}

/// WR-A3 / PM-02 — Account address book. Country-agnostic; TR default.
/// Parent: Account (cascade). Tenant scope: companyId denormalized — must match
/// an AccountCompany.companyId for this account (write-time validation in BFF).
/// `isDefault` uniqueness per (accountId, companyId, type) enforced at app layer
/// inside Prisma transactions (no DB unique to avoid soft-delete race windows).
model Address {
  id               String   @id @default(cuid()) @db.NVarChar(450)
  accountId        String   @db.NVarChar(450)
  /// Denormalized tenant scope. Must equal an AccountCompany.companyId where
  /// AccountCompany.accountId = this.accountId (BFF-enforced).
  companyId        String   @db.NVarChar(450)
  type             String   @db.NVarChar(50) // enum:AddressType
  /// Optional human label (e.g. "İstanbul merkez ofis", "Adana şube").
  label            String?  @db.NVarChar(Max)
  line1            String   @db.NVarChar(Max)
  line2            String?  @db.NVarChar(Max)
  district         String?  @db.NVarChar(Max)
  /// Nullable: country-agnostic — some countries / address formats omit a city.
  city             String?  @db.NVarChar(Max)
  state            String?  @db.NVarChar(255)
  postalCode       String?  @db.NVarChar(255)
  /// ISO 3166-1 alpha-2 (uppercase). App-layer format validation `^[A-Z]{2}$`.
  country          String   @default("TR") @db.NVarChar(Max)
  isDefault        Boolean  @default(false)
  isActive         Boolean  @default(true)
  /// Persistent source-of-truth id from the external ERP/CRM. Optional.
  /// Customer 360 re-imports use (accountId, sourceExternalId) to update
  /// the same Address row instead of creating a duplicate.
  sourceExternalId String?  @db.NVarChar(450)
  createdAt        DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt        DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  company Company @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([accountId])
  @@index([companyId])
  @@index([accountId, type])
  @@index([accountId, isDefault])
  @@index([accountId, sourceExternalId])
}

/// WR-A6 / PM-05 — Tenant-scoped product catalog (foundation only).
/// ProductGroup gruplandırma (örn. UNIVERA "Saha", PARAM "POS"); altında
/// Product (Enroute, ParamPOS vb.).  `code` immutable after create —
/// A7 Package paket-ürün referansları stabil olsun diye.
/// Bu PR'da `supportLevel` field'ı yok (A5 SupportLevel enum shipped olunca
/// ek migration ile gelir).  Mevcut `Case.productGroup` string kolonu ve
/// `AccountProduct` tablosu dokunulmaz — geri uyumluluk.
model ProductGroup {
  id          String   @id @default(cuid()) @db.NVarChar(450)
  companyId   String   @db.NVarChar(450)
  code        String   @db.NVarChar(255)
  name        String   @db.NVarChar(Max)
  description String?  @db.NVarChar(Max)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt   DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products Product[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, isActive])
}

model Product {
  id             String   @id @default(cuid()) @db.NVarChar(450)
  companyId      String   @db.NVarChar(450)
  productGroupId String   @db.NVarChar(450)
  code           String   @db.NVarChar(255)
  name           String   @db.NVarChar(Max)
  description    String?  @db.NVarChar(Max)
  /// WR-A6 follow-up — Varsayılan destek seviyesi. A5 SupportLevel enum
  /// shipped olduktan sonra additive eklendi. Mevcut tüm ürünler default L1.
  /// Phase 2 Case create cascade'inde Product → Person → Team → L1 zincirinin
  /// ilk hint sinyali (A7b sonrası).
  supportLevel   String   @default("L1") @db.NVarChar(50) // enum:SupportLevel
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt      DateTime @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  productGroup    ProductGroup     @relation(fields: [productGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// WR-A7 — Reverse relation for PackageItem assignment.
  packageItems    PackageItem[]
  /// WR-A7b — Reverse relation: bu ürünü referanslayan vakalar.
  cases           Case[]           @relation("CaseProduct")
  /// WR-A8 — Reverse relation: bu ürünü referanslayan müşteri ürün satırları.
  accountProducts AccountProduct[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, productGroupId, isActive])
  @@index([companyId, supportLevel])
}

/// WR-A7 / PM-05 — Tenant-scoped package (contract bundle / subscription plan).
/// Distinct from Product: Product = supported app/module/service; Package =
/// contractual bundle. Examples: UNIVERA WhitePackage/RedPackage,
/// PARAM "POS Başlangıç", FINROTA "Tahsilat Plus".
///
/// IMPORTANT cross-table invariant: every PackageItem.product.companyId
/// MUST equal Package.companyId. Prisma cannot enforce this at DB level;
/// enforced in repository + smoke + data-contract.
model Package {
  id           String   @id @default(cuid()) @db.NVarChar(450)
  companyId    String   @db.NVarChar(450)
  code         String   @db.NVarChar(255)
  name         String   @db.NVarChar(Max)
  description  String?  @db.NVarChar(Max)
  supportLevel String   @default("L1") @db.NVarChar(50) // enum:SupportLevel
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt    DateTime @updatedAt

  company          Company          @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  items            PackageItem[]
  /// WR-A7b — Reverse relation: bu paketi referanslayan AccountCompany'ler.
  accountCompanies AccountCompany[]
  /// WR-A7b — Reverse relation: bu paketi referanslayan vakalar.
  cases            Case[]           @relation("CasePackage")

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@index([companyId, supportLevel])
}

/// WR-A7 — Package ↔ Product join. Composite PK prevents duplicate rows.
/// Product RESTRICT: paketteki ürün hard-delete edilemez (önce paketten
/// çıkar). Package CASCADE: paket silinince üyelikler kalkar.
model PackageItem {
  packageId String   @db.NVarChar(450)
  productId String   @db.NVarChar(450)
  sortOrder Int      @default(0)
  createdAt DateTime @default(dbgenerated("sysutcdatetime()"))

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product Product @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([packageId, productId])
  @@index([productId])
}

/// WR-Smart-Ticket Phase 1a — generic, per-tenant taxonomy table for
/// Smart Ticket intake/closure dropdowns. NOT a replacement for
/// CategoryDef / requestType / Product / etc.; this is an additive
/// vocabulary surface so admins can configure UNIVERA-specific (and
/// other tenants') opening/closure metadata without code changes.
///
/// taxonomyType (string; CHECK opsiyonel ileride) seçilen değerler:
///   "platform"            — Açılış: Backoffice / Mobil
///   "businessProcess"     — Açılış: İş Süreci (UNIVERA: 36 değer)
///   "operationType"       — Açılış: İşlem Tipi (UNIVERA: 25 değer)
///   "affectedObject"      — Açılış: Etkilenen Nesne (UNIVERA: 218 değer)
///   "impact"              — Açılış: Etki (UNIVERA: 6 değer)
///   "rootCauseGroup"      — Kapanış: Kök Neden Grubu (bağımsız düz liste)
///   "rootCauseDetail"     — Kapanış: Kök Neden Detayı (BAĞIMSIZ düz liste;
///                                                       gruba bağlı DEĞİL)
///   "resolutionType"      — Kapanış: Çözüm Tipi (UNIVERA: 12 değer)
///   "permanentPrevention" — Kapanış: Kalıcı Önlem (UNIVERA: 8 değer)
///
/// Kapanış decouple (feature/closure-taxonomy-decouple) — kapanış kategorileri
/// BAĞIMSIZ düz listelerdir; rootCauseDetail artık rootCauseGroup'a bağlanmaz
/// (tüm detaylar her grupta seçilebilir — ürün kararı). parentId kolonu +
/// self-relation şemada forward-compat için durur ama bu akışta yazılmaz/
/// okunmaz; kapanış rows parentId=null.
///
/// Scope: tüm rows tenant-scoped (companyId NOT NULL bu fazda). Global
/// (companyId=null) ileride opsiyonel; şimdilik her tenant kendi seedini
/// taşır. UNIVERA seed script ile XLSX'ten import edilir.
///
/// Constraints:
///   - (companyId, taxonomyType, code) unique → idempotent re-seed
///   - parentId kullanılmaz (decouple) — kapanış kayıtlarında null
///   - active/sortOrder UI ordering için; metadata JSON ileri kullanım
model TaxonomyDef {
  id              String   @id @default(cuid()) @db.NVarChar(450)
  companyId       String   @db.NVarChar(450)
  taxonomyType    String   @db.NVarChar(255)
  code            String   @db.NVarChar(255)
  label           String   @db.NVarChar(Max)
  parentId        String?  @db.NVarChar(450)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  /// Forward-compat: { kbAliases?: string[]; description?: string; … }
  metadata        String?  @db.NVarChar(Max) // json
  /// PR-3 — admin audit attribution (nullable; eski satırlar NULL)
  createdByUserId String?  @db.NVarChar(450)
  updatedByUserId String?  @db.NVarChar(450)
  createdAt       DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt       DateTime @updatedAt

  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parent    TaxonomyDef?  @relation("TaxonomyHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  TaxonomyDef[] @relation("TaxonomyHierarchy")
  createdBy User?         @relation("TaxonomyDefCreatedBy", fields: [createdByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedBy User?         @relation("TaxonomyDefUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([companyId, taxonomyType, code])
  @@index([companyId, taxonomyType, isActive, sortOrder])
  @@index([parentId])
}

/// WR-Smart-Ticket Phase 2a — Case çözüm adımları (L1 agent için).
///
/// Her satır bir somut adım: manuel olarak agent eklemiş olabilir veya
/// External KB / AI `analyze` cevabındaki "AI Önerilen Adımlar"
/// (`analysis.suggestedSteps`) bölümünden import edilmiş olabilir. **Bu
/// fazda yalnız suggested steps import edilir**: root cause hypotheses,
/// customer reply draft, engineer handoff, similar records ve raw response
/// **bilinçli olarak göz ardı edilir**.
///
/// Hayat döngüsü: suggested → tried → worked | not_worked | skipped.
/// outcomeAt/outcomeByUserId terminal status (worked/not_worked/skipped)
/// kararı verildiğinde server tarafında stamplenir.
///
/// Idempotency: aynı (caseId, source='ai_suggested_step', sourceRef)
/// kombinasyonu unique → re-run import duplicate yaratmaz. sourceRef
/// upstream'den gelmiyorsa repository tarafında normalized text üzerinden
/// deterministic hash ile üretilir.
model CaseSolutionStep {
  id              String    @id @default(cuid()) @db.NVarChar(450)
  caseId          String    @db.NVarChar(450)
  /// Multi-tenant izolasyon — DAİMA case.companyId'den türetilir; client
  /// override edemez (route handler scope guard'ı body'deki companyId'i
  /// görmezden gelir).
  companyId       String    @db.NVarChar(450)
  /// 1-based; aynı case içinde benzersiz değil — sadece sıralama için.
  stepIndex       Int
  /// "ai_suggested_step" | "manual" | "external_kb" | "similar_case"
  /// (enum yerine string tutulur: ileride yeni source eklemek için
  /// migration gerekmesin; route + repo whitelist kontrol eder).
  source          String    @db.NVarChar(255)
  /// AI/KB step'in upstream stable id'si veya repo tarafında üretilen
  /// deterministic hash (text+description SHA-256 ilk 16 karakter).
  sourceRef       String?   @db.NVarChar(255)
  sourceTitle     String?   @db.NVarChar(Max)
  title           String    @db.NVarChar(Max)
  description     String?   @db.NVarChar(Max)
  /// "suggested" | "tried" | "worked" | "not_worked" | "skipped"
  status          String    @default("suggested") @db.NVarChar(255)
  note            String?   @db.NVarChar(Max)
  triedAt         DateTime?
  triedByUserId   String?   @db.NVarChar(450)
  outcomeAt       DateTime?
  outcomeByUserId String?   @db.NVarChar(450)
  createdByUserId String?   @db.NVarChar(450)
  createdAt       DateTime  @default(dbgenerated("sysutcdatetime()"))
  updatedAt       DateTime  @updatedAt

  case    Case    @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  company Company @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /// Re-run import idempotency'i — aynı case + AI sourceRef = tek satır.
  /// source='manual' için sourceRef NULL olduğundan multiple satır izin verilir.
  @@unique([caseId, source, sourceRef])
  @@index([caseId, stepIndex])
  @@index([caseId, status])
  @@index([companyId])
  @@index([source, sourceRef])
}

model Team {
  id                  String   @id @default(cuid()) @db.NVarChar(450)
  name                String   @db.NVarChar(Max)
  description         String?  @db.NVarChar(Max)
  // Multi-tenant izolasyon: her takım tek bir şirkete bağlı (holding modeli).
  // listQueries: WHERE companyId IN req.user.allowedCompanyIds.
  companyId           String   @db.NVarChar(450)
  isActive            Boolean  @default(true)
  /// WR-A5 / PM-03 — Takımın varsayılan destek seviyesi. Case create cascade'inde
  /// (assignedPersonId yokken) kullanılır. Mevcut takımlar default L1.
  defaultSupportLevel String   @default("L1") @db.NVarChar(50) // enum:SupportLevel
  /// PR-3 — admin audit attribution (nullable; eski satırlar NULL)
  createdByUserId     String?  @db.NVarChar(450)
  updatedByUserId     String?  @db.NVarChar(450)
  createdAt           DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt           DateTime @updatedAt

  company     Company             @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  members     Person[]
  cases       Case[]
  createdBy   User?               @relation("TeamCreatedBy", fields: [createdByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedBy   User?               @relation("TeamUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// Mail Multi-Inbox (Faz A) — Bu takıma routing edilen inbox'lar (havuz pattern).
  mailInboxes ExternalMailInbox[]

  @@index([companyId])
}

model Person {
  id           String   @id @default(cuid()) @db.NVarChar(450)
  name         String   @db.NVarChar(Max)
  email        String?  @db.NVarChar(Max)
  teamId       String?  @db.NVarChar(450)
  isActive     Boolean  @default(true)
  /// WR-B1 / PM-03 — Takım lideri bayrağı. Phase 2'de escalation hedef seçiminde
  /// hint sinyali; bu PR'da yalnız Admin toggle + smoke invariant.
  isTeamLead   Boolean  @default(false)
  /// WR-A5 / PM-03 — Kişinin destek seviyesi. Case create cascade kaynağı.
  /// Default L1; rol-bazlı seed dağılımı (Agent L1, team lead L2, Admin Expert).
  supportLevel String   @default("L1") @db.NVarChar(50) // enum:SupportLevel
  /// Compose-Signature F1 — Kişinin iş unvanı (örn. "Ürün Direktörü",
  /// "Destek Mühendisi"). Şirket imza şablonundaki {{agent.title}}
  /// placeholder'ı buradan render edilir. Mail outbound'da User.personId
  /// üzerinden join'lenir; SystemAdmin gibi Person'sız user'larda boş
  /// render edilir.
  title        String?  @db.NVarChar(255)
  createdAt    DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt    DateTime @updatedAt

  team                          Team?                      @relation(fields: [teamId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cases                         Case[]                     @relation("CaseAssignedPerson")
  /// WR-D4 Phase 1 — Policies whose approver is this specific person.
  resolutionApprovalPolicies    ResolutionApprovalPolicy[] @relation("ResolutionApprovalPolicyApprover")
  /// WR-D4 Phase 1 — Approval cycles where this person is the resolved approver.
  resolutionApprovalsAsApprover CaseResolutionApproval[]   @relation("CaseResolutionApprovalApprover")
}

model ThirdParty {
  id          String   @id @default(cuid()) @db.NVarChar(450)
  name        String   @db.NVarChar(200)
  description String?  @db.NVarChar(Max)
  isActive    Boolean  @default(true)
  companyId   String?  @db.NVarChar(450)
  pausesSla   Boolean  @default(true)
  createdAt   DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt   DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id])
  cases   Case[]

  @@unique([name, companyId])
}

model DocumentType {
  id          String   @id @default(cuid()) @db.NVarChar(450)
  name        String   @unique @db.NVarChar(200)
  description String?  @db.NVarChar(Max)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt   DateTime @updatedAt
}

// CategoryDef — kategori + alt kategori (self-relation ile parent/child)
model CategoryDef {
  id              String   @id @default(cuid()) @db.NVarChar(450)
  name            String   @db.NVarChar(Max)
  description     String?  @db.NVarChar(Max)
  parentId        String?  @db.NVarChar(450)
  companyId       String?  @db.NVarChar(450)
  isActive        Boolean  @default(true)
  /// PR-3 — admin audit attribution (nullable; eski satırlar NULL)
  createdByUserId String?  @db.NVarChar(450)
  updatedByUserId String?  @db.NVarChar(450)
  createdAt       DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt       DateTime @updatedAt

  parent    CategoryDef?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  CategoryDef[] @relation("CategoryHierarchy")
  company   Company?      @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy User?         @relation("CategoryDefCreatedBy", fields: [createdByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedBy User?         @relation("CategoryDefUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([parentId])
  @@index([companyId])
}

model OfferedSolutionDef {
  id          String   @id @default(cuid()) @db.NVarChar(450)
  name        String   @db.NVarChar(Max)
  description String?  @db.NVarChar(Max)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt   DateTime @updatedAt

  caseOffers CaseOfferedSolution[]
}

// SLAPolicy — esnek eşleşme: companyId zorunlu; diğer alanlar null = wildcard.
// Null alan herhangi bir case değeriyle eşleşir. Birden fazla politika eşleşirse
// non-null alan sayısı (özgüllük puanı) en yüksek olan seçilir.
// MSSQL NULL uniqueness: DB UNIQUE index yerine uygulama katmanında duplicate kontrolü.
model SLAPolicy {
  id              String   @id @default(cuid()) @db.NVarChar(450)
  companyId       String   @db.NVarChar(450)
  companyName     String   @db.NVarChar(Max)
  productGroup    String?  @db.NVarChar(200)
  categoryName    String?  @db.NVarChar(255)
  subCategoryName String?  @db.NVarChar(255)
  requestType     String?  @db.NVarChar(50) // enum:CaseRequestType
  priority        String?  @db.NVarChar(50) // enum:CasePriority (Low/Medium/High/Critical)
  responseHours   Int
  resolutionHours Int
  description     String?  @db.NVarChar(Max)
  isActive        Boolean  @default(true)
  /// PR-3 — admin audit attribution (nullable; eski satırlar NULL)
  createdByUserId String?  @db.NVarChar(450)
  updatedByUserId String?  @db.NVarChar(450)
  createdAt       DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt       DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy User?   @relation("SLAPolicyCreatedBy", fields: [createdByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedBy User?   @relation("SLAPolicyUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([companyId])
}

// ChecklistTemplate — items snapshot olarak Case.checklistItems'a kopyalanır
model ChecklistTemplate {
  id              String   @id @default(cuid()) @db.NVarChar(450)
  name            String   @db.NVarChar(Max)
  companyId       String   @db.NVarChar(450)
  companyName     String   @db.NVarChar(Max)
  productGroup    String   @db.NVarChar(200)
  categoryName    String   @db.NVarChar(255)
  description     String?  @db.NVarChar(Max)
  /// CaseChecklistItem[] — { id, label, required, isActive }
  items           String   @db.NVarChar(Max) // json
  isActive        Boolean  @default(true)
  /// PR-3 — admin audit attribution (nullable; eski satırlar NULL)
  createdByUserId String?  @db.NVarChar(450)
  updatedByUserId String?  @db.NVarChar(450)
  createdAt       DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt       DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy User?   @relation("ChecklistTemplateCreatedBy", fields: [createdByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedBy User?   @relation("ChecklistTemplateUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([companyId, productGroup, categoryName])
}

// ============================================================
// Vaka çekirdek tabloları
// ============================================================

model Case {
  id         String @id @default(cuid()) @db.NVarChar(450)
  caseNumber String @unique @db.NVarChar(50)

  title       String @db.NVarChar(Max)
  description String @db.NVarChar(Max)

  caseType          String  @db.NVarChar(50) // enum:CaseType
  status            String  @default("Acik") @db.NVarChar(50) // enum:CaseStatus
  priority          String  @db.NVarChar(50) // enum:CasePriority
  origin            String  @db.NVarChar(50) // enum:CaseOrigin
  originDescription String? @db.NVarChar(255)

  // Şirket / Müşteri (denormalized — ad alanları arşiv için)
  companyId   String  @db.NVarChar(450)
  companyName String  @db.NVarChar(Max)
  // Phase C2: accountId nullable — Agent müşteriyi tanıyamadığında vaka
  // "müşterisiz" açılabilir; Supervisor/Admin sonra eşleştirir.
  accountId   String? @db.NVarChar(450)
  accountName String? @db.NVarChar(Max)

  // WR-A4 / PM-04 — Proje bazlı vaka takip (UNIVERA core).
  // AccountCompany üzerinden bağlı; Account-level değil. Mevcut tüm vakalarda
  // null kalır. CompanySettings.projectsRequired=true tenant'larda Case create
  // sırasında accountId varsa accountProjectId zorunlu olur (app-layer check).
  accountProjectId   String? @db.NVarChar(450)
  accountProjectName String? @db.NVarChar(Max)

  // Sınıflandırma (denormalized — kategori adları)
  category     String  @db.NVarChar(255)
  subCategory  String  @db.NVarChar(255)
  requestType  String  @db.NVarChar(50) // enum:CaseRequestType
  /// Legacy free-text productGroup. WR-A7b sonrası yeni vakalarda productId/productName tercih edilir;
  /// mevcut vakalar korunur, otomatik backfill yok.
  productGroup String? @db.NVarChar(Max)

  // WR-A7b / PM-05 — Catalog entegrasyonu. productId/packageId opsiyonel referans;
  // productName/packageName snapshot (arşiv için, catalog silinse de korunur).
  // Cross-table invariants DI.1-DI.6 app-layer'da enforce edilir.
  productId   String? @db.NVarChar(450)
  productName String? @db.NVarChar(Max)
  packageId   String? @db.NVarChar(450)
  packageName String? @db.NVarChar(Max)

  // Atama (FK + denormalized name)
  assignedTeamId     String? @db.NVarChar(450)
  assignedTeamName   String? @db.NVarChar(Max)
  assignedPersonId   String? @db.NVarChar(450)
  assignedPersonName String? @db.NVarChar(Max)

  // Vaka Sahibi — vakayı açan kullanıcı (creator). Atamadan bağımsız,
  // sadece create() set eder; claim/atama/devir asla değiştirmez.
  createdByUserId String? @db.NVarChar(450)
  createdByName   String? @db.NVarChar(Max)

  // Eskalasyon
  escalationLevel String @default("Yok") @db.NVarChar(50) // enum:EscalationLevel

  // WR-A5 / PM-03 — Vakanın destek seviyesi (L1/L2/L3/Expert). Create cascade:
  //   assignedPersonId → Person.supportLevel
  //   else assignedTeamId → Team.defaultSupportLevel
  //   else default L1
  // Phase 1 foundation: SLA/escalation tier-aware rewrite Phase 2'de.
  supportLevel String @default("L1") @db.NVarChar(50) // enum:SupportLevel

  // 3rd party
  thirdPartyId   String? @db.NVarChar(450)
  thirdPartyName String? @db.NVarChar(Max)

  // ProactiveTracking alanları
  financialStatus  String? @db.NVarChar(50) // enum:FinancialStatus
  productUsage     String? @db.NVarChar(50) // enum:ProductUsage
  usageChangeAlert String? @db.NVarChar(50) // enum:UsageChangeAlert
  responseLevel    String? @db.NVarChar(50) // enum:ResponseLevel

  // Churn alanları
  cancellationRequest  Boolean?
  /// String[] — OfferedSolutionDef.id listesi
  offeredSolutions     String?   @db.NVarChar(Max) // json
  offerExpiryDate      DateTime?
  offerOutcome         String?   @db.NVarChar(50) // enum:OfferOutcome
  offerRejectionReason String?   @db.NVarChar(Max)
  actionTaken          String?   @db.NVarChar(Max)
  churnResult          String?   @db.NVarChar(50) // enum:ChurnResult
  retentionStatus      String?   @db.NVarChar(50) // enum:RetentionStatus
  followUpDate         DateTime?

  // Çözüm / iptal
  resolutionNote     String? @db.NVarChar(Max)
  cancellationReason String? @db.NVarChar(Max)

  // WR-D4 Phase 1 — Resolution approval overlay. Source of truth is
  // CaseResolutionApproval (audit table); this denormalized field is
  // updated whenever an approval row is inserted or decided so listings
  // and CaseDetail can render the current state without joining.
  // null = no approval cycle has ever started on this case.
  approvalState String? @db.NVarChar(50) // enum:ApprovalState

  // WR-D4 Phase 2 — communication overlay. Tracks whether external/manual
  // communication has fired for this case after a close/approval event.
  // Phase 2 values: 'Pending' (rule matched, awaiting operator confirm),
  // 'Manual' (operator confirmed), 'Dispatched' (Phase 4 active send), or
  // 'NotRequired' (no rule matched). Free-string for forward compat.
  communicationState String? @db.NVarChar(255)

  // WR-D4/D3 Phase 3 — per-case channel override. Operator can decide that
  // for THIS case the customer should be reached on email even though
  // AccountCompany prefers phone (or vice versa). Override is the channel
  // preference only; the actual identifier still comes from the fallback
  // chain (responseEmail → AccountContact.email → Account.email).
  // Values mirror AccountCompany.preferredResponseChannel; free-string for
  // forward compat with channels added later.
  communicationChannelOverride String? @db.NVarChar(255)

  // SLA
  slaResponseDueAt       DateTime?
  slaResolutionDueAt     DateTime?
  slaViolation           Boolean   @default(false)
  slaPausedAt            DateTime?
  slaPausedDurationMin   Int       @default(0)
  slaThirdPartyWaitMin   Int       @default(0)
  slaResponseMetAt       DateTime? // ilk yanıt verildiğinde (Incelemede'ye geçiş)
  slaResolutionStartedAt DateTime? // vakayı ilk üstlenen kişinin claim zamanı

  // Phase D — Müşteri Eşleştirme: accountId NULL ile açılan vakalar bu flag
  // ile işaretlenir. Supervisor/Admin "Müşteri Eşleştirilmemiş" kuyruğunda
  // görür ve PATCH /api/cases/:id/link-account ile bağlar. accountId set
  // edilen vakalarda her zaman false.
  customerMatchPending Boolean @default(false)

  // Phase D Step 2 — müşterisiz vaka açılırken Agent'ın aldığı başvuran
  // bilgileri (opsiyonel). Eşleştirme öneri motoru bu alanları yüksek-öncelik
  // sinyal olarak kullanır. Analytics/AI payload'lara DAHIL EDİLMEZ.
  customerContactName  String? @db.NVarChar(Max)
  customerContactPhone String? @db.NVarChar(Max)
  customerContactEmail String? @db.NVarChar(Max)
  customerCompanyName  String? @db.NVarChar(Max)

  // AI alanları
  aiSummary                  String? @db.NVarChar(Max)
  aiCategoryPrediction       String? @db.NVarChar(Max)
  aiPriorityPrediction       String? @db.NVarChar(50) // enum:CasePriority
  aiDuplicateScore           Float?
  aiConfidenceScore          Float?
  aiGeneratedFlag            Boolean @default(false)
  aiRejectReason             String? @db.NVarChar(Max)
  aiCallBrief                String? @db.NVarChar(Max)
  aiFollowupRecommendation   String? @db.NVarChar(Max)
  aiRetentionOfferSuggestion String? @db.NVarChar(Max)
  // RUNA AI Faz 3 — supervisor-summary çıktısının persist edilen iki alanı.
  // riskLevel: 'Düşük'|'Orta'|'Yüksek'|'Kritik' (string tutulur — mevcut
  // aiPriorityPrediction pattern'i ile uyumlu, ileride genişletilebilir).
  // keyPoints: JSON array<string> (MSSQL JSON tipi yok — customFields aynı).
  aiRiskLevel                String? @db.NVarChar(50)
  aiKeyPoints                String? @db.NVarChar(Max)

  // PR-SD — Soft archive (SystemAdmin-only UI temizliği). Hard delete YOK;
  // arşivli vaka tüm child kayıtlarıyla intact kalır, sadece liste/detay
  // default exclude'la gizlenir. status enum dokunulmaz — archive orthogonal
  // bayrak. archivedByUserId User FK (audit).
  isArchived       Boolean   @default(false)
  archivedAt       DateTime?
  archivedByUserId String?   @db.NVarChar(450)
  archiveReason    String?   @db.NVarChar(Max)

  // Checklist (snapshot — template sonradan değişirse vaka etkilenmez)
  /// CaseChecklistItemInstance[] — { id, templateItemId, label, required, checked, checkedAt?, checkedBy? }
  checklistItems String? @db.NVarChar(Max) // json

  // Custom Fields — şirket FieldDefinition'larına göre dinamik alanlar.
  /// { [fieldKey: string]: any } — değer tipi FieldType'a bağlı
  customFields String? @db.NVarChar(Max) // json

  // Snooze — vaka geçici olarak Inbox'tan kaldırılıp Later sekmesine taşınır.
  // snoozePreviousStatus: erteleme öncesi statü; unsnooze/cron-wakeup'ta buna
  // dönülür (3rdPartyBekleniyor gibi statüler korunsun diye). Yoksa Acik fallback.
  snoozeUntil          DateTime?
  snoozeReason         String?   @db.NVarChar(50) // enum:SnoozeReason
  snoozePreviousStatus String?   @db.NVarChar(50) // enum:CaseStatus

  // QA Skor — Faz 1.5 Madde 4 (Smart QA Lite). Kapatılmış vakalarda AI 3 kriter
  // üzerinden 1-5 puan üretir + kısa feedback. null = henüz skorlanmadı (cron
  // sıraya girmemiş veya Cozuldu değil).
  qaEmpathyScore Int?
  qaClarityScore Int?
  qaSpeedScore   Int?
  qaFeedback     String?   @db.NVarChar(Max)
  qaScoredAt     DateTime?

  // Aktarım sayacı (FAZ 2 §20.2 — Vaka Aktarımı). Her başarılı transfer
  // sonrası +1; >=2 olduğunda supervisor uyarısı + AI kök neden analizi
  // tetiklenir. CaseTransfer kayıtları tam audit izi tutar.
  transferCount Int @default(0)

  createdAt  DateTime  @default(dbgenerated("sysutcdatetime()"))
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  // Relations
  company        Company         @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  account        Account?        @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  accountProject AccountProject? @relation(fields: [accountProjectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedTeam   Team?           @relation(fields: [assignedTeamId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedPerson Person?         @relation("CaseAssignedPerson", fields: [assignedPersonId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy      User?           @relation("CaseCreatedBy", fields: [createdByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  thirdParty     ThirdParty?     @relation(fields: [thirdPartyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// WR-A7b — Catalog Product referansı (opsiyonel).
  product        Product?        @relation("CaseProduct", fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// WR-A7b — Catalog Package referansı (opsiyonel).
  package        Package?        @relation("CasePackage", fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// PR-SD — Soft archive actor (User FK; audit için JOIN).
  archivedByUser User?           @relation("CaseArchivedBy", fields: [archivedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  notes                  CaseNote[]
  attachments            CaseAttachment[]
  history                CaseActivity[]
  callLogs               CaseCallLog[]
  caseOffers             CaseOfferedSolution[]
  approvals              CaseApproval[]
  /// WR-D4 Phase 1 — Per-case resolution approval cycles (immutable history).
  resolutionApprovals    CaseResolutionApproval[]
  /// WR-D4 Phase 2 — Per-case notification dispatch log (rule engine output).
  notificationDispatches NotificationDispatch[]
  notifications          CaseNotification[]
  aiSuggestions          AISuggestion[]
  mentions               CaseMention[]
  reminders              CaseReminder[]
  transfers              CaseTransfer[]
  watchers               CaseWatcher[]
  /// Vaka Etiket Doğrulama Ekranı — açılış/kapanış etiketleme kontrolü (1:1).
  taggingReview          CaseTaggingReview?
  // Case A → linkedCaseId: A "outgoing" links (CaseLinkSource).
  // Case B ← linkedCaseId: B "incoming" links (CaseLinkTarget).
  outgoingLinks          CaseLink[]               @relation("CaseLinkSource")
  incomingLinks          CaseLink[]               @relation("CaseLinkTarget")
  /// WR-Smart-Ticket Phase 2a — L1 agent çözüm adımları (manual + AI önerisi).
  solutionSteps          CaseSolutionStep[]

  // Mail M6.1 — İletişim takip alanları (K4).
  // Türetim caseEmailRepository.append* + caseRepository.transitionStatus
  // terminal geçişi içinde. UI: thread sort + "yanıt bekliyor" rozeti
  // (M6.3'te list/board üzerine).
  /// Son inbound mail zamanı (CaseEmail.receivedAt referans).
  lastEmailInboundAt   DateTime?
  /// Son outbound mail zamanı (CaseEmail.sentAt referans).
  lastEmailOutboundAt  DateTime?
  /// Müşteri yanıt bekliyor mu? Türetim:
  ///   - inbound → true
  ///   - outbound → false
  ///   - transitionStatus(terminal) → false
  pendingCustomerReply Boolean   @default(false)

  /// Mail M6.1 — Vakaya ait CaseEmail satırları (gelen + giden +
  /// otomatik dispatch). MailThread bu listeden beslenir.
  caseEmails CaseEmail[]

  @@index([accountId])
  @@index([accountProjectId])
  @@index([companyId])
  @@index([assignedPersonId])
  @@index([assignedTeamId])
  @@index([status])
  @@index([caseType])
  @@index([createdAt])
  @@index([slaResolutionDueAt])
  @@index([slaResponseDueAt])
  @@index([snoozeUntil])
  // Analytics dashboard composite indexler (Operations Intelligence Phase 1):
  // companyId + tarih aralığı + statü/team/category hot path'leri için.
  // Mevcut tek-sütun index'lere ek; downtime'sız additive.
  @@index([companyId, createdAt])
  @@index([companyId, status])
  @@index([companyId, assignedTeamId])
  @@index([companyId, category, subCategory])
  @@index([companyId, resolvedAt])
  // WR-A5 / PM-03 — tier filter / routing Phase 2 için.
  @@index([companyId, supportLevel])
  // PR-SD — list default exclude path için. companyId zaten her sorguda.
  @@index([companyId, isArchived])
  // WR-A7b — Catalog filter / report path'leri için.
  @@index([companyId, productId])
  @@index([companyId, packageId])
  /// M6.1 — "Yanıt bekliyor" filtresi (M6.3 list/board) için.
  @@index([companyId, pendingCustomerReply])
}

// CaseReminder — Faz 2 §6 "Bana Hatırlat" özelliği. Kullanıcı bir vakayı
// gelecekte hatırlamak istediğinde bu kayıt oluşur. Cron veya kullanıcı oturumu
// tarafından remindAt anında bildirim üretilir; sentAt sıfırlanma anına işaret eder.
//
// caseId opsiyonel — vakaya bağlı değil de kişisel bir notu hatırlatmak için
// boş bırakılabilir (örn. "Aylık raporları gözden geçir").
//
// companyId NOT NULL — Case'den denormalize ya da vakasız reminder'da
// kullanıcının ilk allowedCompanyId'sinden dolar. Multi-tenant scope filter
// JOIN'siz çalışabilsin diye (Faz 1.5 child denorm pattern'i).
model CaseReminder {
  id        String    @id @default(cuid()) @db.NVarChar(450)
  caseId    String?   @db.NVarChar(450)
  userId    String    @db.NVarChar(450)
  companyId String    @db.NVarChar(450)
  remindAt  DateTime
  message   String?   @db.NVarChar(Max)
  sentAt    DateTime?
  createdAt DateTime  @default(dbgenerated("sysutcdatetime()"))

  case Case? @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, remindAt])
  @@index([caseId])
  @@index([companyId])
}

// CaseActivity — her değişiklik kaydı (audit trail)
// companyId Case'den denormalize — top-level audit/raporlama sorgularında
// JOIN gerektirmesin, multi-tenant scope filter doğrudan uygulansın.
model CaseActivity {
  id          String   @id @default(cuid()) @db.NVarChar(450)
  caseId      String   @db.NVarChar(450)
  companyId   String   @db.NVarChar(450)
  action      String   @db.NVarChar(Max) // human-readable
  actionType  String?  @db.NVarChar(50) // enum:CaseHistoryActionType
  fieldName   String?  @db.NVarChar(Max)
  fromValue   String?  @db.NVarChar(Max)
  toValue     String?  @db.NVarChar(Max)
  note        String?  @db.NVarChar(Max)
  actor       String   @db.NVarChar(Max)
  /// PR-5 — Optional FK to User (audit drift fix). Eski satırlar NULL kalır;
  /// display chain: actorUserId varsa canlı User.fullName, yoksa actor string.
  actorUserId String?  @db.NVarChar(450)
  at          DateTime @default(dbgenerated("sysutcdatetime()"))

  case      Case  @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  actorUser User? @relation("CaseActivityActor", fields: [actorUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([caseId])
  @@index([companyId])
  @@index([at])
  @@index([actorUserId])
}

model CaseNote {
  id           String   @id @default(cuid()) @db.NVarChar(450)
  caseId       String   @db.NVarChar(450)
  companyId    String   @db.NVarChar(450)
  authorName   String   @db.NVarChar(Max)
  // authorId — User.id; reaksiyon/yanıt bildirimleri için gerekir.
  // Nullable: eski notlarda boş, yeni eklenenlerde dolu.
  authorId     String?  @db.NVarChar(450)
  content      String   @db.NVarChar(Max)
  visibility   String   @default("Internal") @db.NVarChar(50) // enum:NoteVisibility
  parentNoteId String?  @db.NVarChar(450)
  replyCount   Int      @default(0)
  createdAt    DateTime @default(dbgenerated("sysutcdatetime()"))

  case      Case               @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  // MSSQL: self-relation SetNull olamaz — parent note silinirken parentNoteId
  // uygulama katmanında null'lanmalı (caseRepository note delete akışı).
  parent    CaseNote?          @relation("NoteReplies", fields: [parentNoteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   CaseNote[]         @relation("NoteReplies")
  reactions CaseNoteReaction[]

  @@index([caseId])
  @@index([companyId])
  @@index([parentNoteId])
}

// CaseNoteReaction — bir nota (top-level veya reply) emoji reaksiyonu.
// Sabit whitelist (UI seviyesinde + BFF seviyesinde dogrulanir):
// "thumbs_up" | "eyes" | "check" | "important" | "thanks"
// Unique (noteId, userId, emoji) — bir kullanici ayni emoji'yi iki kez veremez;
// ikinci tiklamada toggle remove yapilir.
// onDelete Cascade — note silinirse reaksiyonlar da gider.
model CaseNoteReaction {
  id        String   @id @default(cuid()) @db.NVarChar(450)
  noteId    String   @db.NVarChar(450)
  userId    String   @db.NVarChar(450)
  companyId String   @db.NVarChar(450)
  emoji     String   @db.NVarChar(50)
  createdAt DateTime @default(dbgenerated("sysutcdatetime()"))

  note CaseNote @relation(fields: [noteId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([noteId, userId, emoji])
  @@index([noteId])
  @@index([userId])
  @@index([companyId])
}

// MetricQueryAudit — Operations Intelligence Dashboard Phase 1.
// Her analytics overview/drilldown/export çağrısı bir audit satırı bırakır.
// HR/audit talepleri için 1 yıl+ retention (cleanup cron Phase 5+).
// docs/OPERATIONS_DASHBOARD_DESIGN.md §2.6.6'da detay.
model MetricQueryAudit {
  id                String   @id @default(cuid()) @db.NVarChar(450)
  userId            String   @db.NVarChar(450)
  userRole          String   @db.NVarChar(255) // snapshot — rol o anki haliyle saklanır
  endpoint          String   @db.NVarChar(255) // 'overview' | 'drilldown' | 'export' | 'ai-insights' vs.
  scopeFingerprint  String   @db.NVarChar(255) // hash(scope.companyIds + teamIds + personIds)
  scopeKind         String   @db.NVarChar(255) // 'self' | 'team' | 'company' | 'cross-company'
  filterFingerprint String   @db.NVarChar(Max) // hash(appliedFilters)
  formulaVersion    String   @db.NVarChar(Max) // metric definition versiyonu (v1 sabit)
  generatedAt       DateTime @default(dbgenerated("sysutcdatetime()"))
  durationMs        Int
  recordsScanned    Int? // approximate; Phase 1 için opsiyonel
  responseHash      String?  @db.NVarChar(Max) // opsiyonel — sonraki replay/diff için

  @@index([userId, generatedAt])
  @@index([endpoint, generatedAt])
  @@index([scopeFingerprint])
}

model CaseAttachment {
  id               String   @id @default(cuid()) @db.NVarChar(450)
  caseId           String   @db.NVarChar(450)
  companyId        String   @db.NVarChar(450)
  fileName         String   @db.NVarChar(Max)
  fileSize         Int
  mimeType         String   @db.NVarChar(255)
  fileUrl          String?  @db.NVarChar(Max) // Supabase Storage URL (mock'ta dataUrl)
  uploadedBy       String   @db.NVarChar(Max)
  /// PR-5 — Optional FK to User (audit drift fix). Eski satırlar NULL kalır;
  /// display chain: uploadedByUserId varsa canlı User.fullName, yoksa uploadedBy string.
  uploadedByUserId String?  @db.NVarChar(450)
  uploadedAt       DateTime @default(dbgenerated("sysutcdatetime()"))

  case           Case  @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  uploadedByUser User? @relation("CaseAttachmentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([caseId])
  @@index([companyId])
  @@index([uploadedByUserId])
}

model CaseCallLog {
